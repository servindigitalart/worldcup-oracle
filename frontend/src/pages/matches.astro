---
import Layout from '../layouts/Layout.astro';
import ProbBar from '../components/ProbBar.astro';
import Disclaimer from '../components/Disclaimer.astro';
import EmptyState from '../components/EmptyState.astro';
import { loadJson } from '../utils/load';
import { formatTeamName, formatKickoff, formatPct } from '../utils/format';
import type { BlendedPrediction, FixtureScheduleEntry, MatchBettingCard } from '../types';

interface FixtureSource {
  source: string | null;
  is_official: boolean;
  is_placeholder: boolean;
  description: string;
  total_fixtures: number;
  total_groups: number;
}

const predictions    = loadJson<BlendedPrediction[]>('blended_predictions.json', []);
const fixtureSource  = loadJson<FixtureSource>('fixture_source.json', {
  source: null,
  is_official: false,
  is_placeholder: true,
  description: '',
  total_fixtures: 0,
  total_groups: 0,
});
const schedule = loadJson<Record<string, FixtureScheduleEntry>>('fixture_schedule.json', {});
const bettingCards = loadJson<MatchBettingCard[]>('match_betting_cards.json', []);

// Index betting cards by match_id for quick lookup
const signalByMid: Record<string, MatchBettingCard> = {};
for (const card of bettingCards) {
  signalByMid[card.match_id] = card;
}

// Group matches by group letter
const byGroup: Record<string, BlendedPrediction[]> = {};
for (const m of predictions) {
  if (!byGroup[m.group]) byGroup[m.group] = [];
  byGroup[m.group].push(m);
}
const groups = Object.keys(byGroup).sort();

const isPlaceholder = fixtureSource.is_placeholder !== false;
const sourceLabel   = fixtureSource.source ?? 'unknown';

function getSchedule(home: string, away: string): FixtureScheduleEntry | null {
  return schedule[`${home}_vs_${away}`] ?? schedule[`${away}_vs_${home}`] ?? null;
}
---
<Layout title="Matches" description="Group-stage match probabilities">
  <div class="space-y-8">

    <div>
      <h1 class="text-3xl font-bold text-slate-100">Group Stage Matches</h1>
      <p class="mt-2 text-slate-400">
        Blended probabilities (80% market / 20% model by default).
        Matches without market data use model-only predictions.
      </p>
    </div>

    <!-- Fixture data status banner -->
    {isPlaceholder ? (
      <div class="rounded-xl border border-amber-800/50 bg-amber-950/40 px-4 py-3 text-sm">
        <p class="font-semibold text-amber-400">Placeholder fixture data</p>
        <p class="mt-1 text-amber-300/80">
          Groups and matchups are derived from a placeholder draw, not the official
          FIFA 2026 schedule. Source: <code class="text-amber-200">{sourceLabel}</code>.
          Probabilities will update automatically once <code class="text-amber-200">data/seed/wc2026_fixtures.json</code> is
          replaced with official data and the pipeline is rerun.
        </p>
      </div>
    ) : (
      <div class="rounded-xl border border-emerald-800/50 bg-emerald-950/40 px-4 py-3 text-sm">
        <p class="font-semibold text-emerald-400">Official FIFA 2026 fixture data</p>
        <p class="mt-1 text-emerald-300/80">
          Groups and kickoff times reflect the official FIFA 2026 World Cup schedule.
          Source: <code class="text-emerald-200">{sourceLabel}</code>.
          {fixtureSource.total_fixtures > 0 && (
            <> {fixtureSource.total_fixtures} group-stage fixtures across {fixtureSource.total_groups} groups.</>
          )}
        </p>
      </div>
    )}

    <Disclaimer compact />

    <!-- Legend -->
    <div class="flex flex-wrap gap-4 text-xs text-slate-500">
      <span class="flex items-center gap-1.5">
        <span class="w-3 h-3 rounded-sm bg-blue-700 inline-block"></span> Home win
      </span>
      <span class="flex items-center gap-1.5">
        <span class="w-3 h-3 rounded-sm bg-slate-600 inline-block"></span> Draw
      </span>
      <span class="flex items-center gap-1.5">
        <span class="w-3 h-3 rounded-sm bg-rose-800 inline-block"></span> Away win
      </span>
      <span class="text-slate-600">· Probabilities are neutral-venue estimates.</span>
    </div>

    {predictions.length === 0 ? (
      <EmptyState
        title="No predictions available"
        message="Run the blend pipeline to generate match probabilities."
        command="make blend"
      />
    ) : (
      <div class="space-y-10">
        {groups.map((g) => (
          <section>
            <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-4">
              Group {g}
              {isPlaceholder && (
                <span class="ml-2 text-xs font-normal text-amber-600 normal-case tracking-normal">
                  placeholder
                </span>
              )}
            </h2>
            <div class="space-y-3">
              {byGroup[g].map((m) => {
                const fix = getSchedule(m.home_team, m.away_team);
                const card = signalByMid[m.match_id];
                const topSig = card?.top_signals?.[0];
                const signalLevel = topSig?.signal_level;
                const signalBadgeClass = signalLevel === 'strong_signal'   ? 'bg-blue-900/50 text-blue-300 border-blue-700/50'
                                       : signalLevel === 'moderate_signal' ? 'bg-indigo-900/50 text-indigo-300 border-indigo-700/50'
                                       : signalLevel === 'watch'           ? 'bg-amber-900/50 text-amber-300 border-amber-700/50'
                                       : '';
                const hasSignal = signalLevel && ['strong_signal', 'moderate_signal', 'watch'].includes(signalLevel);
                const selLabel = {
                  home_win: 'Home win', draw: 'Draw', away_win: 'Away win',
                  home_or_draw: 'Home/Draw', home_or_away: 'Home/Away', draw_or_away: 'Draw/Away',
                  yes: 'BTTS yes', no: 'BTTS no', over: 'Over', under: 'Under',
                };
                return (
                  <div class="bg-slate-900 border border-slate-800 rounded-xl px-4 py-3">
                    <div class="flex items-start justify-between gap-2 mb-2">
                      <div class="flex-1 min-w-0">
                        <ProbBar
                          home={m.blend_home}
                          draw={m.blend_draw}
                          away={m.blend_away}
                          homeLabel={formatTeamName(m.home_team)}
                          awayLabel={formatTeamName(m.away_team)}
                        />
                      </div>
                      {card && (
                        <a
                          href={`/match/${m.match_id}`}
                          class="text-xs text-slate-500 hover:text-blue-400 shrink-0 transition-colors"
                        >
                          detail →
                        </a>
                      )}
                    </div>
                    <div class="flex justify-between text-xs text-slate-600">
                      <span>{(m.blend_home * 100).toFixed(1)}%</span>
                      <span class="text-slate-500">
                        {m.has_market_data ? 'blend' : 'model only'}
                      </span>
                      <span>{(m.blend_away * 100).toFixed(1)}%</span>
                    </div>
                    {hasSignal && topSig && (
                      <div class="mt-2 flex items-center gap-2">
                        <span class:list={[
                          'text-xs px-1.5 py-0.5 rounded border font-medium',
                          signalBadgeClass,
                        ]}>
                          {signalLevel === 'watch' ? 'Watch' : 'Model edge'}
                        </span>
                        <span class="text-xs text-slate-500">
                          {selLabel[topSig.selection] ?? topSig.selection}
                          {' · '}{formatPct(topSig.probability)}
                          {topSig.market_gap != null && (
                            <span class={topSig.market_gap > 0 ? 'text-blue-400' : 'text-red-400'}>
                              {' '}({topSig.market_gap > 0 ? '+' : ''}{formatPct(topSig.market_gap, 1)})
                            </span>
                          )}
                        </span>
                      </div>
                    )}
                    {fix && (fix.kickoff_at || fix.venue) && (
                      <div class="mt-2 text-xs text-slate-600 flex flex-wrap gap-x-3">
                        {fix.kickoff_at && (
                          <span>{formatKickoff(fix.kickoff_at)}</span>
                        )}
                        {fix.venue && fix.city && (
                          <span class="text-slate-700">{fix.venue}, {fix.city}</span>
                        )}
                      </div>
                    )}
                  </div>
                );
              })}
            </div>
          </section>
        ))}
      </div>
    )}
  </div>
</Layout>
