---
import Layout from '../layouts/Layout.astro';
import StatCard from '../components/StatCard.astro';
import EmptyState from '../components/EmptyState.astro';
import { loadJson } from '../utils/load';
import { formatRps, formatDate, formatModelName } from '../utils/format';
import type { BacktestSummary, HoldoutSummary, ModelComparison } from '../types';

const backtest   = loadJson<BacktestSummary | null>('backtest_summary.json', null);
const holdout    = loadJson<HoldoutSummary | null>('holdout_summary.json', null);
const comparison = loadJson<ModelComparison | null>('model_comparison.json', null);

const MODEL_KEYS = ['elo-baseline-v0.2', 'elo-baseline-v0.2-recent', 'dixon-coles-v0.3'];
const years = backtest ? Object.keys(backtest.per_year).sort() : [];
---
<Layout title="Model" description="Model performance — Elo, Dixon-Coles, backtest">
  <div class="space-y-10">

    <div>
      <h1 class="text-3xl font-bold text-slate-100">Model Performance</h1>
      <p class="mt-2 text-slate-400">
        Ranked Probability Score (RPS) across 2014, 2018, and 2022 WC group stages.
        Lower RPS = better calibration. Uniform random baseline = 0.25.
      </p>
    </div>

    {(!backtest && !holdout) ? (
      <EmptyState
        title="No model data"
        message="Run the holdout and backtest pipelines first."
        command="make holdout && make backtest"
      />
    ) : (
      <>
        <!-- Quick stats -->
        {comparison && (
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            <StatCard label="Total matches" value={comparison.total_matches} />
            <StatCard label="Uniform RPS baseline" value={comparison.uniform_rps.toFixed(2)} />
            <StatCard
              label="Best model"
              value={formatModelName(comparison.models[0]?.model ?? '')}
              sub={`RPS ${comparison.models[0]?.mean_rps?.toFixed(4)}`}
            />
            <StatCard
              label="Models evaluated"
              value={comparison.models.length}
            />
          </div>
        )}

        <!-- Multi-year backtest table -->
        {backtest && (
          <section>
            <h2 class="text-lg font-semibold text-slate-200 mb-1">
              Multi-Year Backtest — RPS by Model
            </h2>
            <p class="text-xs text-slate-500 mb-4">{backtest.small_sample_note}</p>

            <div class="bg-slate-900 border border-slate-800 rounded-xl overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-slate-800 text-xs text-slate-500 uppercase tracking-wider">
                    <th class="text-left px-4 py-3 font-semibold">Model</th>
                    {years.map(y => (
                      <th class="text-right px-4 py-3 font-semibold">{y}</th>
                    ))}
                    {backtest.aggregate && (
                      <th class="text-right px-4 py-3 font-semibold text-slate-400">Aggregate</th>
                    )}
                  </tr>
                </thead>
                <tbody>
                  {MODEL_KEYS.map((mk) => {
                    const aggEntry = backtest.aggregate?.[mk];
                    return (
                      <tr class="border-b border-slate-800/60 last:border-0 hover:bg-slate-800/30">
                        <td class="px-4 py-3 text-slate-200 font-medium">
                          {formatModelName(mk)}
                        </td>
                        {years.map(y => {
                          const rps = backtest.per_year[y]?.rps?.[mk];
                          const beats = backtest.per_year[y]?.beats_uniform?.[mk];
                          return (
                            <td class="px-4 py-3 text-right tabular-nums">
                              <span class:list={[
                                beats ? 'text-green-400' : 'text-rose-400',
                                'font-mono text-xs',
                              ]}>
                                {rps != null ? rps.toFixed(4) : '—'}
                              </span>
                            </td>
                          );
                        })}
                        {aggEntry && (
                          <td class="px-4 py-3 text-right tabular-nums">
                            <span class:list={[
                              aggEntry.beats_uniform ? 'text-green-400 font-semibold' : 'text-rose-400',
                              'font-mono text-xs',
                            ]}>
                              {aggEntry.mean_rps?.toFixed(4)}
                            </span>
                          </td>
                        )}
                      </tr>
                    );
                  })}
                  <!-- Baseline row -->
                  <tr class="border-t border-slate-700/50">
                    <td class="px-4 py-3 text-slate-500 italic">Uniform baseline</td>
                    {years.map(() => (
                      <td class="px-4 py-3 text-right font-mono text-xs text-slate-600">
                        {backtest.uniform_rps.toFixed(4)}
                      </td>
                    ))}
                    {backtest.aggregate && (
                      <td class="px-4 py-3 text-right font-mono text-xs text-slate-600">
                        {backtest.uniform_rps.toFixed(4)}
                      </td>
                    )}
                  </tr>
                </tbody>
              </table>
            </div>
            <p class="text-xs text-slate-600 mt-2">
              Green = beats uniform baseline. Lower RPS is better.
            </p>
          </section>
        )}

        <!-- 2022 holdout -->
        {holdout && (
          <section>
            <h2 class="text-lg font-semibold text-slate-200 mb-4">
              2022 WC Holdout — {holdout.holdout_name}
            </h2>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
              <StatCard label="Training matches" value={holdout.n_train_matches.toLocaleString()} />
              <StatCard label="Holdout matches" value={holdout.n_holdout_scored} sub={`of ${holdout.n_holdout_total} total`} />
              <StatCard
                label="Mean RPS"
                value={holdout.mean_rps.toFixed(4)}
                accent
                sub={holdout.beats_uniform ? 'Beats uniform baseline' : 'Does not beat baseline'}
              />
              <StatCard label="Model" value={formatModelName(holdout.model_version)} sub={`cutoff: ${holdout.train_cutoff}`} />
            </div>
            <p class="text-xs text-slate-500 mt-3">{holdout.small_sample_note ?? ''}</p>
          </section>
        )}

        <!-- RPS explanation -->
        <section class="bg-slate-900 border border-slate-800 rounded-xl p-5">
          <h3 class="text-sm font-semibold text-slate-300 mb-2">What is RPS?</h3>
          <p class="text-xs text-slate-500 leading-relaxed">
            Ranked Probability Score measures calibration for ordinal outcomes (home win / draw / away win).
            Lower is better. A model always predicting 1/3 probability for each outcome scores 0.25.
            Values below 0.25 mean the model adds information above the naive uniform prior.
            Differences smaller than ~0.01 across 48 matches should be treated as directional, not conclusive.
          </p>
        </section>
      </>
    )}
  </div>
</Layout>
