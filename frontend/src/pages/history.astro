---
import Layout from '../layouts/Layout.astro';
import { loadJson } from '../utils/load';
import { formatTeamName, formatPct } from '../utils/format';
import type { PredictionLedgerEntry } from '../types';

const ledger = loadJson<PredictionLedgerEntry[]>('prediction_ledger.json', []);

const hasData   = ledger.length > 0;
const graded    = ledger.filter((r: PredictionLedgerEntry) => r.result_known);
const pending   = ledger.filter((r: PredictionLedgerEntry) => !r.result_known);
const withRec   = ledger.filter((r: PredictionLedgerEntry) => r.recommendation_type === 'model_gap_detected');

// Sorted newest first
const sorted = [...ledger].sort((a, b) =>
  (b.generated_at ?? '').localeCompare(a.generated_at ?? '')
);

function outcomeLabel(r: PredictionLedgerEntry): string {
  if (!r.result_known || !r.outcome) return '—';
  if (r.outcome === 'home_win') return `${formatTeamName(r.home_team)} win`;
  if (r.outcome === 'away_win') return `${formatTeamName(r.away_team)} win`;
  return 'Draw';
}

function scoreline(r: PredictionLedgerEntry): string {
  if (!r.result_known || r.home_goals == null) return '';
  return `${r.home_goals}–${r.away_goals}`;
}

function fmt4(v: number | null | undefined): string {
  if (v == null || !isFinite(v)) return '—';
  return v.toFixed(4);
}

function fmtPct(v: number | null | undefined): string {
  if (v == null || !isFinite(v)) return '—';
  return (v * 100).toFixed(1) + '%';
}

function fmtEdge(v: number | null | undefined): string {
  if (v == null || !isFinite(v)) return '—';
  const sign = v > 0 ? '+' : '';
  return sign + (v * 100).toFixed(1) + 'pp';
}

function recBadge(r: PredictionLedgerEntry): string {
  if (!r.recommendation_type || r.recommendation_type === 'no_recommendation') return '';
  if (r.recommendation_type === 'model_gap_detected') return 'bg-blue-900/50 text-blue-300 border-blue-700/50';
  if (r.recommendation_type === 'watch') return 'bg-amber-900/50 text-amber-300 border-amber-700/50';
  return 'bg-slate-800 text-slate-400 border-slate-600';
}

function recLabel(r: PredictionLedgerEntry): string {
  if (!r.recommendation_type || r.recommendation_type === 'no_recommendation') return '';
  if (r.recommendation_type === 'model_gap_detected') {
    return r.recommendation_selection ? `Gap: ${r.recommendation_selection.replace('_', ' ')}` : 'Model gap';
  }
  if (r.recommendation_type === 'watch') return 'Watch';
  return r.recommendation_type.replace(/_/g, ' ');
}

function correctClass(r: PredictionLedgerEntry): string {
  if (!r.result_known || r.correct_side == null) return 'text-slate-500';
  return r.correct_side ? 'text-emerald-400' : 'text-red-400';
}
---

<Layout title="Prediction History" description="Full prediction ledger with graded outcomes, Brier scores, and CLV.">
  <h1 class="text-2xl font-bold text-white mb-1">Prediction History</h1>
  <p class="text-slate-400 text-sm mb-6">
    Full prediction ledger — one entry per match snapshot. Graded automatically once results are known.
  </p>

  {!hasData && (
    <div class="rounded-lg border border-slate-700 bg-slate-900 px-6 py-10 text-center">
      <p class="text-slate-400 text-sm">No predictions captured yet.</p>
      <p class="text-slate-500 text-xs mt-2">
        Run <code class="font-mono">make refresh-live</code> to capture and grade predictions.
      </p>
    </div>
  )}

  {hasData && (
    <>
      {/* ── Summary stats ──────────────────────────────────────────────────── */}
      <div class="flex gap-4 flex-wrap mb-6 text-sm">
        <span class="text-slate-400">
          <span class="text-white font-semibold">{ledger.length}</span> total
        </span>
        <span class="text-slate-400">
          <span class="text-emerald-400 font-semibold">{graded.length}</span> graded
        </span>
        <span class="text-slate-400">
          <span class="text-amber-400 font-semibold">{pending.length}</span> pending
        </span>
        <span class="text-slate-400">
          <span class="text-blue-400 font-semibold">{withRec.length}</span> with model gap signal
        </span>
      </div>

      {/* ── Ledger table ────────────────────────────────────────────────────── */}
      <div class="rounded-lg border border-slate-700 bg-slate-900 overflow-x-auto">
        <table class="w-full text-xs sm:text-sm min-w-[900px]">
          <thead>
            <tr class="border-b border-slate-700 text-xs text-slate-500 uppercase tracking-wide">
              <th class="px-3 py-3 text-left">Date</th>
              <th class="px-3 py-3 text-left">Match</th>
              <th class="px-3 py-3 text-right">Model H/D/A</th>
              <th class="px-3 py-3 text-right">Market H/D/A</th>
              <th class="px-3 py-3 text-center">Signal</th>
              <th class="px-3 py-3 text-left">Result</th>
              <th class="px-3 py-3 text-right">Brier</th>
              <th class="px-3 py-3 text-right">RPS</th>
              <th class="px-3 py-3 text-right">CLV (snap)</th>
              <th class="px-3 py-3 text-center">Correct?</th>
            </tr>
          </thead>
          <tbody>
            {sorted.map((r: PredictionLedgerEntry, i: number) => {
              const badge = recBadge(r);
              const label = recLabel(r);
              return (
                <tr class={`${i < sorted.length - 1 ? 'border-b border-slate-800' : ''} hover:bg-slate-800/30`}>
                  <td class="px-3 py-2.5 text-slate-500 whitespace-nowrap">
                    {r.generated_at ? r.generated_at.slice(0, 10) : '—'}
                  </td>
                  <td class="px-3 py-2.5 text-slate-300 whitespace-nowrap">
                    <span class="text-slate-200">{formatTeamName(r.home_team)}</span>
                    <span class="text-slate-600 mx-1">vs</span>
                    <span class="text-slate-200">{formatTeamName(r.away_team)}</span>
                    <span class="ml-1.5 text-slate-600 text-xs">{r.group}</span>
                  </td>
                  <td class="px-3 py-2.5 text-right font-mono text-slate-400 whitespace-nowrap">
                    {fmtPct(r.home_win_prob)} /
                    {fmtPct(r.draw_prob)} /
                    {fmtPct(r.away_win_prob)}
                  </td>
                  <td class="px-3 py-2.5 text-right font-mono text-slate-500 whitespace-nowrap">
                    {r.market_home_prob != null
                      ? `${fmtPct(r.market_home_prob)} / ${fmtPct(r.market_draw_prob)} / ${fmtPct(r.market_away_prob)}`
                      : '—'}
                  </td>
                  <td class="px-3 py-2.5 text-center">
                    {badge ? (
                      <span class={`inline-block px-2 py-0.5 rounded border text-xs ${badge}`}>
                        {label}
                      </span>
                    ) : (
                      <span class="text-slate-700">—</span>
                    )}
                  </td>
                  <td class="px-3 py-2.5 text-slate-300 whitespace-nowrap">
                    {r.result_known ? (
                      <span>
                        <span class="font-mono text-slate-400">{scoreline(r)}</span>
                        <span class="ml-1.5 text-slate-300">{outcomeLabel(r)}</span>
                      </span>
                    ) : (
                      <span class="text-amber-500 text-xs">pending</span>
                    )}
                  </td>
                  <td class="px-3 py-2.5 text-right font-mono text-slate-400">
                    {fmt4(r.brier)}
                  </td>
                  <td class="px-3 py-2.5 text-right font-mono text-slate-400">
                    {fmt4(r.rps)}
                  </td>
                  <td class="px-3 py-2.5 text-right font-mono text-slate-500">
                    {(() => {
                      const sel = r.recommendation_selection;
                      const v = sel === 'home' ? r.clv_home
                              : sel === 'draw' ? r.clv_draw
                              : sel === 'away' ? r.clv_away
                              : r.clv_home;
                      if (v == null || !isFinite(v)) return '—';
                      const sign = v > 0 ? '+' : '';
                      return sign + (v * 100).toFixed(1) + 'pp';
                    })()}
                  </td>
                  <td class={`px-3 py-2.5 text-center font-medium ${correctClass(r)}`}>
                    {r.result_known && r.correct_side != null
                      ? (r.correct_side ? '✓' : '✗')
                      : '—'}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      <p class="text-xs text-slate-600 mt-3">
        Model probabilities shown at prediction capture time. Brier and RPS are for the model's
        probability set. 'Correct?' reflects whether the model's highest-probability side matched
        the actual outcome — not a betting call.
      </p>
    </>
  )}
</Layout>
