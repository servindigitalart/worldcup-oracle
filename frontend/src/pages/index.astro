---
import Layout from '../layouts/Layout.astro';
import Disclaimer from '../components/Disclaimer.astro';
import StatCard from '../components/StatCard.astro';
import EmptyState from '../components/EmptyState.astro';
import { loadJson } from '../utils/load';
import { formatTeamName, formatPct, formatDate, formatKickoff } from '../utils/format';
import type { SimSummary, MarketBlend, CaptureStatus, RefreshReport, MatchBettingCard, BettingSummary } from '../types';

const sim      = loadJson<SimSummary | null>('sim_summary.json', null);
const blend    = loadJson<MarketBlend | null>('market_blend.json', null);
const capture  = loadJson<CaptureStatus | null>('capture_status.json', null);
const refresh  = loadJson<RefreshReport | null>('refresh_report.json', null);
const cards    = loadJson<MatchBettingCard[]>('match_betting_cards.json', []);
const bSummary = loadJson<BettingSummary | null>('betting_summary.json', null);

// Top signals: cards with at least one signal, sorted by signal strength then kickoff
const SIGNAL_ORDER: Record<string, number> = {
  strong_signal:   0,
  moderate_signal: 1,
  watch:           2,
};
const withSignals = cards
  .filter(c => c.top_signals.length > 0)
  .sort((a, b) => {
    const aLevel = SIGNAL_ORDER[a.top_signals[0]?.signal_level ?? ''] ?? 9;
    const bLevel = SIGNAL_ORDER[b.top_signals[0]?.signal_level ?? ''] ?? 9;
    if (aLevel !== bLevel) return aLevel - bLevel;
    return (a.kickoff_at ?? '').localeCompare(b.kickoff_at ?? '');
  })
  .slice(0, 6);

function signalBadgeClass(level: string): string {
  switch (level) {
    case 'strong_signal':   return 'bg-blue-900/50 text-blue-300 border-blue-700/50';
    case 'moderate_signal': return 'bg-indigo-900/50 text-indigo-300 border-indigo-700/50';
    case 'watch':           return 'bg-amber-900/50 text-amber-300 border-amber-700/50';
    default:                return 'bg-slate-800 text-slate-400 border-slate-700';
  }
}

function signalLabel(level: string): string {
  switch (level) {
    case 'strong_signal':   return 'Model edge';
    case 'moderate_signal': return 'Model edge';
    case 'watch':           return 'Watch';
    default:                return level;
  }
}

const selMap: Record<string, string> = {
  home_win: 'Home win', draw: 'Draw', away_win: 'Away win',
  home_or_draw: 'Home/Draw', home_or_away: 'Home/Away', draw_or_away: 'Draw/Away',
  yes: 'BTTS yes', no: 'BTTS no', over: 'Over', under: 'Under',
};
---
<Layout title="Overview">
  <div class="space-y-8">

    <!-- Header -->
    <div>
      <h1 class="text-3xl font-bold text-slate-100">World Cup 2026 Oracle</h1>
      <p class="mt-2 text-slate-400 max-w-2xl">
        Multi-market betting intelligence — Elo + Dixon-Coles models blended with market odds.
        Educational signals only. Not betting advice.
      </p>
    </div>

    <Disclaimer />

    <!-- Upcoming betting signals -->
    {withSignals.length > 0 ? (
      <section>
        <div class="flex items-baseline justify-between mb-4">
          <h2 class="text-lg font-semibold text-slate-200">
            Upcoming Betting Signals
            <span class="text-sm font-normal text-slate-500 ml-2">educational only</span>
          </h2>
          <a href="/matches" class="text-sm text-blue-400 hover:text-blue-300">
            All matches →
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {withSignals.map((card) => {
            const sig = card.top_signals[0];
            const home = formatTeamName(card.home_team);
            const away = formatTeamName(card.away_team);
            return (
              <a
                href={`/match/${card.match_id}`}
                class="bg-slate-900 border border-slate-800 rounded-xl p-4 hover:border-slate-600 transition-colors block space-y-3"
              >
                <div class="flex items-center justify-between gap-2">
                  <div class="text-xs text-slate-500 uppercase tracking-wide">
                    Group {card.group}
                  </div>
                  <span class:list={[
                    'text-xs px-2 py-0.5 rounded border font-medium shrink-0',
                    signalBadgeClass(sig.signal_level),
                  ]}>
                    {signalLabel(sig.signal_level)}
                  </span>
                </div>
                <div>
                  <div class="text-slate-200 font-semibold text-sm">{home} vs {away}</div>
                  {card.kickoff_at && (
                    <div class="text-xs text-slate-500 mt-0.5">{formatKickoff(card.kickoff_at)}</div>
                  )}
                </div>
                <div class="text-xs text-slate-400">
                  <span class="text-slate-300">{selMap[sig.selection] ?? sig.selection}</span>
                  {' · '}model {formatPct(sig.probability)}
                  {sig.market_gap != null && (
                    <span class:list={[
                      'ml-1',
                      sig.market_gap > 0 ? 'text-blue-400' : 'text-red-400',
                    ]}>
                      ({sig.market_gap > 0 ? '+' : ''}{formatPct(sig.market_gap, 1)} gap)
                    </span>
                  )}
                </div>
              </a>
            );
          })}
        </div>
        {bSummary && (
          <p class="text-xs text-slate-500 mt-3">
            {bSummary.n_signals} signal{bSummary.n_signals !== 1 ? 's' : ''} across {bSummary.n_matches} matches
            {bSummary.n_with_dc_grid > 0 && ` · ${bSummary.n_with_dc_grid} with Dixon-Coles goal markets`}
          </p>
        )}
      </section>
    ) : (
      <div class="rounded-xl border border-slate-800 bg-slate-900/50 px-4 py-5 text-sm text-slate-400">
        <p class="font-medium text-slate-300 mb-1">No signals available</p>
        <p>Run <code class="text-xs bg-slate-800 px-1 rounded">make betting</code> to generate match betting signals.</p>
      </div>
    )}

    {sim ? (
      <>
        <!-- Quick stats -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          <StatCard label="Simulations" value={sim.n_sims.toLocaleString()} />
          <StatCard label="Teams" value="48" sub="12 groups, 4 teams each" />
          <StatCard label="Match model" value={sim.locked_model.split('-')[0].toUpperCase()} sub={sim.locked_model} />
          <StatCard label="Generated" value={formatDate(sim.generated_date)} />
        </div>

        <!-- Top champion picks -->
        <section>
          <h2 class="text-lg font-semibold text-slate-200 mb-4">
            Top Champion Probabilities
            <span class="text-sm font-normal text-slate-500 ml-2">({sim.n_sims.toLocaleString()} simulations)</span>
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {sim.top_champion_probs.slice(0, 12).map((row, i) => (
              <div class="bg-slate-900 border border-slate-800 rounded-xl px-4 py-3 flex items-center gap-3">
                <span class="text-slate-600 text-sm font-mono w-5 text-right shrink-0">{i + 1}</span>
                <div class="flex-1 min-w-0">
                  <div class="text-slate-200 font-medium text-sm truncate">
                    {formatTeamName(row.team)}
                  </div>
                </div>
                <div class="text-blue-400 font-semibold text-sm shrink-0">
                  {formatPct(row.champion)}
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- Pipeline status -->
        <section>
          <h2 class="text-lg font-semibold text-slate-200 mb-4">Pipeline Status</h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="bg-slate-900 border border-slate-800 rounded-xl p-4">
              <div class="text-xs text-slate-500 uppercase tracking-wider mb-1">Goals model</div>
              <div class="text-sm text-slate-200 font-medium">{sim.goals_model_version}</div>
              <div class="text-xs text-slate-500 mt-1">Group-stage scorelines</div>
            </div>
            {blend && (
              <div class="bg-slate-900 border border-slate-800 rounded-xl p-4">
                <div class="text-xs text-slate-500 uppercase tracking-wider mb-1">Blend weights</div>
                <div class="text-sm text-slate-200 font-medium">
                  {(blend.market_weight * 100).toFixed(0)}% market /
                  {(blend.model_weight * 100).toFixed(0)}% model
                </div>
                <div class="text-xs text-slate-500 mt-1">
                  {blend.n_with_market} of {blend.n_matchups_total} with market data
                </div>
              </div>
            )}
            {capture && (
              <div class="bg-slate-900 border border-slate-800 rounded-xl p-4">
                <div class="text-xs text-slate-500 uppercase tracking-wider mb-1">Capture status</div>
                <div class="text-sm text-slate-200 font-medium">
                  {capture.n_total_snapshots} snapshots
                </div>
                <div class="text-xs text-slate-500 mt-1">
                  {capture.has_real_api_key ? 'Live market data' : 'Dummy provider'}
                </div>
              </div>
            )}
          </div>
        </section>

        <!-- Last refresh -->
        {refresh && (
          <section>
            <h2 class="text-lg font-semibold text-slate-200 mb-3">Last Refresh</h2>
            <a href="/status" class="block bg-slate-900 border border-slate-800 rounded-xl p-4 hover:border-slate-600 transition-colors">
              <div class="flex items-center justify-between flex-wrap gap-3">
                <div class="flex items-center gap-3">
                  <span class:list={[
                    'w-2.5 h-2.5 rounded-full shrink-0',
                    refresh.success ? 'bg-green-500' : 'bg-red-500',
                  ]} />
                  <div>
                    <div class="text-sm font-medium text-slate-200">
                      {refresh.success ? 'Refresh succeeded' : 'Refresh failed'}
                    </div>
                    <div class="text-xs text-slate-500 mt-0.5">{refresh.summary}</div>
                  </div>
                </div>
                <div class="text-right text-xs text-slate-600 shrink-0">
                  <div>{refresh.n_steps_success}/{refresh.n_steps_total} steps</div>
                  <div class="mt-0.5">{refresh.total_duration_seconds.toFixed(1)}s</div>
                </div>
              </div>
            </a>
          </section>
        )}
      </>
    ) : (
      <EmptyState
        title="No simulation data"
        message="Run the simulation pipeline to generate tournament probabilities."
        command="make simulate"
      />
    )}
  </div>
</Layout>
