---
import Layout from '../layouts/Layout.astro';
import HeroSignalCard from '../components/HeroSignalCard.astro';
import UpcomingMatchCard from '../components/UpcomingMatchCard.astro';
import TrustStrip from '../components/TrustStrip.astro';
import EmptyState from '../components/EmptyState.astro';
import { loadJson } from '../utils/load';
import { formatTeamName, formatPct, formatKickoff } from '../utils/format';
import type {
  SimSummary,
  MarketBlend,
  BlendedPrediction,
  FixtureScheduleEntry,
  Recommendation,
  RecommendationsSummary,
  RefreshReport,
} from '../types';

const sim       = loadJson<SimSummary | null>('sim_summary.json', null);
const blend     = loadJson<MarketBlend | null>('market_blend.json', null);
const refresh   = loadJson<RefreshReport | null>('refresh_report.json', null);
const predictions = loadJson<BlendedPrediction[]>('blended_predictions.json', []);
const schedule  = loadJson<Record<string, FixtureScheduleEntry>>('fixture_schedule.json', {});
const recs      = loadJson<Recommendation[]>('recommendations.json', []);
const recSummary = loadJson<RecommendationsSummary | null>('recommendations_summary.json', null);

// ── Enrich predictions with kickoff/venue and recommendation signal level ──
function getSchedule(home: string, away: string): FixtureScheduleEntry | null {
  return schedule[`${home}_vs_${away}`] ?? schedule[`${away}_vs_${home}`] ?? null;
}

const recByMatch: Record<string, Recommendation> = {};
for (const r of recs) {
  recByMatch[r.match_id] = r;
}

interface EnrichedMatch extends BlendedPrediction {
  kickoff_at: string | null;
  venue: string | null;
  city: string | null;
  signalLevel: string | undefined;
}

const enriched: EnrichedMatch[] = predictions.map((p) => {
  const fix = getSchedule(p.home_team, p.away_team);
  const rec = recByMatch[p.match_id];
  const signalLevel = rec && ['model_gap_detected', 'watch', 'avoid'].includes(rec.recommendation_type)
    ? rec.recommendation_type
    : undefined;
  return {
    ...p,
    kickoff_at: fix?.kickoff_at ?? null,
    venue: fix?.venue ?? null,
    city: fix?.city ?? null,
    signalLevel,
  };
});

const upcoming = [...enriched]
  .filter((m) => m.kickoff_at)
  .sort((a, b) => (a.kickoff_at ?? '').localeCompare(b.kickoff_at ?? ''));

const nextSix = upcoming.slice(0, 6);

// ── Hero spotlight: strongest available signal, else most decisive model pick ──
const hasMarketData = (blend?.n_with_market ?? 0) > 0;

const withRecSignal = upcoming.filter((m) => m.signalLevel);
const spotlight = withRecSignal[0] ?? [...upcoming]
  .sort((a, b) => {
    const maxA = Math.max(a.blend_home, a.blend_draw, a.blend_away);
    const maxB = Math.max(b.blend_home, b.blend_draw, b.blend_away);
    return maxB - maxA;
  })[0];

// ── Stats for hero strip ──
const totalUpcoming = upcoming.length;
const nSignals = recSummary?.n_actionable ?? 0;
const marketCoverageLabel = hasMarketData
  ? `${blend?.n_with_market ?? 0} of ${blend?.n_matchups_total ?? totalUpcoming} matches`
  : 'Connecting';

function lastUpdatedLabel(): string {
  if (!refresh?.generated_at) return '—';
  try {
    const d = new Date(refresh.generated_at);
    const now = new Date();
    const hours = Math.round((now.getTime() - d.getTime()) / 3600000);
    if (hours < 1) return 'Just now';
    if (hours < 24) return `${hours}h ago`;
    const days = Math.round(hours / 24);
    return `${days}d ago`;
  } catch {
    return '—';
  }
}
---
<Layout title="Overview">
  <div class="space-y-14">

    <!-- ════════════════════════ HERO ════════════════════════ -->
    <section class="relative -mt-2">
      <div class="max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-widest text-cyan-600 mb-3">
          World Cup 2026 · Betting Intelligence
        </p>
        <h1 class="text-3xl sm:text-4xl font-bold text-slate-100 tracking-tight leading-tight">
          Find where the World Cup market
          <span class="text-cyan-400">disagrees with the model.</span>
        </h1>
        <p class="mt-4 text-slate-400 text-base leading-relaxed max-w-2xl">
          World Cup Oracle compares Elo and Dixon-Coles model probabilities against market odds
          to surface match-level signals — where they agree, where they diverge, and by how much.
          Educational only — not betting advice.
        </p>
      </div>

      <!-- Stat pills -->
      <div class="mt-7 grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="rounded-lg border border-slate-800/70 bg-slate-900/50 px-4 py-3">
          <div class="text-xl font-bold text-slate-100">{totalUpcoming}</div>
          <div class="text-[11px] text-slate-500 mt-0.5">Upcoming matches</div>
        </div>
        <div class="rounded-lg border border-slate-800/70 bg-slate-900/50 px-4 py-3">
          <div class:list={['text-xl font-bold', nSignals > 0 ? 'text-cyan-400' : 'text-slate-100']}>
            {nSignals}
          </div>
          <div class="text-[11px] text-slate-500 mt-0.5">Signals detected</div>
        </div>
        <div class="rounded-lg border border-slate-800/70 bg-slate-900/50 px-4 py-3">
          <div class="text-xl font-bold text-slate-100">{marketCoverageLabel}</div>
          <div class="text-[11px] text-slate-500 mt-0.5">Market odds available</div>
        </div>
        <div class="rounded-lg border border-slate-800/70 bg-slate-900/50 px-4 py-3">
          <div class="text-xl font-bold text-slate-100">{lastUpdatedLabel()}</div>
          <div class="text-[11px] text-slate-500 mt-0.5">Latest update</div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ FEATURED SIGNAL ═══════════════════ -->
    {spotlight ? (
      <section>
        <HeroSignalCard
          match={spotlight}
          homeLabel={formatTeamName(spotlight.home_team)}
          awayLabel={formatTeamName(spotlight.away_team)}
          kickoffFormatted={formatKickoff(spotlight.kickoff_at)}
        />
      </section>
    ) : (
      <EmptyState
        title="No match data yet"
        message="Match probabilities will appear here once the next update runs."
      />
    )}

    <!-- ═══════════════════ UPCOMING MATCHES ═══════════════════ -->
    {nextSix.length > 0 && (
      <section>
        <div class="flex items-baseline justify-between mb-4">
          <h2 class="text-lg font-semibold text-slate-200">Upcoming Matches</h2>
          <a href="/matches" class="text-sm text-blue-400 hover:text-blue-300 transition-colors">
            All matches →
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {nextSix.map((m) => (
            <UpcomingMatchCard
              match_id={m.match_id}
              homeLabel={formatTeamName(m.home_team)}
              awayLabel={formatTeamName(m.away_team)}
              group={m.group}
              kickoffFormatted={formatKickoff(m.kickoff_at)}
              city={m.city}
              blend_home={m.blend_home}
              blend_draw={m.blend_draw}
              blend_away={m.blend_away}
              has_market_data={m.has_market_data}
              signalLevel={m.signalLevel}
            />
          ))}
        </div>
      </section>
    )}

    <!-- ═══════════════════ MARKET INTELLIGENCE ═══════════════════ -->
    <section class="rounded-xl border border-slate-800/70 bg-slate-900/40 px-5 py-5">
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
          <h2 class="text-sm font-semibold text-slate-300 mb-1.5">Market Intelligence</h2>
          {hasMarketData ? (
            <p class="text-sm text-slate-500 max-w-xl leading-relaxed">
              Market odds are connected for {marketCoverageLabel}. Signals above reflect real
              gaps between model probability and market-implied probability.
            </p>
          ) : (
            <p class="text-sm text-slate-500 max-w-xl leading-relaxed">
              Real market odds are not yet connected. Every match above shows a model probability
              only — there is no market benchmark to compare against. Once odds are captured,
              this section will surface the matches where the model and market disagree most.
            </p>
          )}
        </div>
        <a href="/market" class="shrink-0 text-sm text-blue-400 hover:text-blue-300 transition-colors">
          Market data →
        </a>
      </div>
    </section>

    <!-- ═══════════════════ TOURNAMENT PULSE ═══════════════════ -->
    {sim && (
      <section>
        <div class="flex items-baseline justify-between mb-4">
          <h2 class="text-lg font-semibold text-slate-200">
            Tournament Pulse
            <span class="text-sm font-normal text-slate-500 ml-2">
              {sim.n_sims.toLocaleString()} simulations
            </span>
          </h2>
          <a href="/tournament" class="text-sm text-blue-400 hover:text-blue-300 transition-colors">
            Full odds →
          </a>
        </div>
        <div class="rounded-xl border border-slate-800/70 bg-slate-900/40 p-5 space-y-2.5">
          {sim.top_champion_probs.slice(0, 5).map((row, i) => (
            <div class="flex items-center gap-3">
              <span class="text-slate-600 text-xs font-mono w-4 shrink-0">{i + 1}</span>
              <span class="text-sm text-slate-300 w-32 sm:w-40 truncate shrink-0">
                {formatTeamName(row.team)}
              </span>
              <div class="flex-1 h-4 bg-slate-800/80 rounded-full overflow-hidden">
                <div
                  class="h-full bg-gradient-to-r from-blue-700 to-cyan-600 rounded-full"
                  style={`width: ${Math.max(row.champion * 100, 1.5)}%`}
                />
              </div>
              <span class="text-cyan-400 text-sm font-semibold w-12 text-right shrink-0">
                {formatPct(row.champion)}
              </span>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- ═══════════════════ TRUST STRIP ═══════════════════ -->
    {sim && (
      <section>
        <TrustStrip nSims={sim.n_sims} goalsModel={sim.goals_model_version} />
      </section>
    )}

    <!-- ═══════════════════ EXPLORE ═══════════════════ -->
    <section class="pb-4">
      <h2 class="text-xs font-bold uppercase tracking-widest text-slate-600 mb-4">Explore</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-2.5">
        <a
          href="/recommendations"
          class="flex flex-col items-center justify-center rounded-xl border border-cyan-800/40 bg-cyan-950/20 hover:bg-cyan-950/35 px-4 py-4 text-center transition-colors group"
        >
          <span class="text-sm font-semibold text-cyan-400 group-hover:text-cyan-300 transition-colors">Signals</span>
          <span class="text-[10px] text-slate-600 mt-1">Betting intelligence</span>
        </a>
        <a
          href="/matches"
          class="flex flex-col items-center justify-center rounded-xl border border-blue-800/40 bg-blue-950/20 hover:bg-blue-950/35 px-4 py-4 text-center transition-colors group"
        >
          <span class="text-sm font-semibold text-blue-400 group-hover:text-blue-300 transition-colors">Matches</span>
          <span class="text-[10px] text-slate-600 mt-1">All 72 fixtures</span>
        </a>
        <a
          href="/tournament"
          class="flex flex-col items-center justify-center rounded-xl border border-slate-700/50 bg-slate-900/50 hover:bg-slate-900 px-4 py-4 text-center transition-colors group"
        >
          <span class="text-sm font-semibold text-slate-300 group-hover:text-slate-100 transition-colors">Tournament</span>
          <span class="text-[10px] text-slate-600 mt-1">Championship odds</span>
        </a>
        <a
          href="/bracket"
          class="flex flex-col items-center justify-center rounded-xl border border-slate-700/50 bg-slate-900/50 hover:bg-slate-900 px-4 py-4 text-center transition-colors group"
        >
          <span class="text-sm font-semibold text-slate-300 group-hover:text-slate-100 transition-colors">Bracket</span>
          <span class="text-[10px] text-slate-600 mt-1">Knockout stage</span>
        </a>
      </div>
    </section>

  </div>
</Layout>
