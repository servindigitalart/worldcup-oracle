---
import Layout from '../layouts/Layout.astro';
import Disclaimer from '../components/Disclaimer.astro';
import EmptyState from '../components/EmptyState.astro';
import { loadJson } from '../utils/load';
import { formatTeamName, formatPct } from '../utils/format';
import type { TeamProb, SimSummary } from '../types';

const teams  = loadJson<TeamProb[]>('team_probs.json', []);
const sim    = loadJson<SimSummary | null>('sim_summary.json', null);

const sorted = [...teams].sort((a, b) => b.champion - a.champion);

const stages: Array<{ key: keyof TeamProb; label: string }> = [
  { key: 'qualify',  label: 'Qualify' },
  { key: 'r16',      label: 'R16'     },
  { key: 'qf',       label: 'QF'      },
  { key: 'sf',       label: 'SF'      },
  { key: 'final',    label: 'Final'   },
  { key: 'champion', label: 'Win'     },
];

function champBar(p: number): string {
  const w = Math.round(p * 100);
  return `width: ${Math.max(w, 1)}%`;
}
---
<Layout title="Tournament" description="WC 2026 tournament stage probabilities">
  <div class="space-y-8">

    <div>
      <h1 class="text-3xl font-bold text-slate-100">Tournament Probabilities</h1>
      <p class="mt-2 text-slate-400">
        {sim
          ? `${sim.n_sims.toLocaleString()} Monte Carlo simulations. ${sim.locked_model} × ${sim.goals_model_version}.`
          : 'Monte Carlo tournament simulation results.'}
      </p>
    </div>

    <Disclaimer compact />

    {teams.length === 0 ? (
      <EmptyState
        title="No simulation data"
        message="Run the simulation pipeline to generate tournament probabilities."
        command="make simulate"
      />
    ) : (
      <>
        <!-- Column header -->
        <div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden">
          <!-- Sticky header row -->
          <div class="grid grid-cols-[2rem_1fr_repeat(6,4.5rem)] gap-0 border-b border-slate-800
                      text-xs font-semibold text-slate-500 uppercase tracking-wider px-4 py-3">
            <span>#</span>
            <span>Team</span>
            {stages.map(s => <span class="text-right">{s.label}</span>)}
          </div>

          {sorted.map((row, i) => (
            <div class:list={[
              'grid grid-cols-[2rem_1fr_repeat(6,4.5rem)] gap-0 px-4 py-2.5 text-sm',
              'border-b border-slate-800/60 last:border-0',
              i < 8 ? 'bg-slate-900' : 'bg-slate-950/30',
            ]}>
              <span class="text-slate-600 text-xs font-mono self-center">{i + 1}</span>
              <span class="text-slate-200 font-medium self-center truncate pr-2">
                {formatTeamName(row.team)}
              </span>
              {stages.map(s => {
                const val = row[s.key] as number;
                return (
                  <span class:list={[
                    'text-right self-center tabular-nums',
                    s.key === 'champion'
                      ? (val >= 0.10 ? 'text-blue-400 font-semibold' : 'text-slate-300')
                      : 'text-slate-400',
                  ]}>
                    {formatPct(val, 0)}
                  </span>
                );
              })}
            </div>
          ))}
        </div>

        <!-- Champion probability bars (top 16) -->
        <section>
          <h2 class="text-lg font-semibold text-slate-200 mb-4">Champion Probability</h2>
          <div class="space-y-2">
            {sorted.slice(0, 16).map((row) => (
              <div class="flex items-center gap-3">
                <span class="text-slate-300 text-sm w-36 truncate shrink-0">
                  {formatTeamName(row.team)}
                </span>
                <div class="flex-1 h-5 bg-slate-800 rounded-full overflow-hidden">
                  <div
                    class="h-full bg-blue-700 rounded-full"
                    style={champBar(row.champion)}
                  />
                </div>
                <span class="text-blue-400 text-sm font-semibold w-12 text-right tabular-nums shrink-0">
                  {formatPct(row.champion)}
                </span>
              </div>
            ))}
          </div>
        </section>

        {sim && (
          <p class="text-xs text-slate-600">
            {sim.disclaimers.group_draw} {sim.disclaimers.bracket}
          </p>
        )}
      </>
    )}
  </div>
</Layout>
