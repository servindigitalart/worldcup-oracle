---
import Layout from '../layouts/Layout.astro';
import ForecastTeamCard from '../components/ForecastTeamCard.astro';
import TrustStrip from '../components/TrustStrip.astro';
import RelatedLinks from '../components/RelatedLinks.astro';
import { loadJson } from '../utils/load';
import { formatTeamName, formatPct } from '../utils/format';
import type { TeamProb, SimSummary } from '../types';

const teams = loadJson<TeamProb[]>('team_probs.json', []);
const sim   = loadJson<SimSummary | null>('sim_summary.json', null);

const sorted = [...teams].sort((a, b) => b.champion - a.champion);
const champMax = sorted.length > 0 ? sorted[0].champion : 1;

const top8 = sorted.slice(0, 8);
const top16 = sorted.slice(0, 16);

const safeFavorites  = sorted.filter(t => t.qualify >= 0.88);
const contested      = sorted.filter(t => t.qualify >= 0.55 && t.qualify < 0.88);
const longshots      = sorted.filter(t => t.qualify < 0.55);

const topName   = sorted.length > 0 ? formatTeamName(sorted[0].team) : '';
const topChamp  = sorted.length > 0 ? formatPct(sorted[0].champion) : '—';
const nSims     = sim?.n_sims ?? 10000;
const goalsModel = sim?.goals_model_version ?? 'dixon-coles';

const champBarW = (p: number) => 'width:' + Math.max(p * 100, 0.5).toFixed(2) + '%';
---

<Layout title="World Cup Forecast" description="Championship probabilities, qualification odds, and round-by-round projections for the 2026 World Cup.">

  <!-- SECTION 1: Hero -->
  <div class="mb-12">
    <div class="flex items-center gap-2 mb-3">
      <span class="text-[10px] font-semibold uppercase tracking-widest text-slate-600">Monte Carlo</span>
      <span class="text-slate-800">·</span>
      <span class="text-[10px] font-semibold uppercase tracking-widest text-slate-600">{nSims.toLocaleString()} Simulations</span>
    </div>
    <h1 class="text-3xl sm:text-4xl font-bold text-slate-100 tracking-tight mb-2">World Cup Forecast</h1>
    <p class="text-slate-500 text-sm mb-6 max-w-lg">
      Championship odds, qualification projections, and round-by-round probabilities for all 48 teams.
    </p>
    <div class="flex flex-wrap gap-2.5">
      <span class="inline-flex items-center gap-1.5 text-xs text-slate-400 bg-slate-800/60 border border-slate-700/50 px-3 py-1.5 rounded-full">
        <span class="font-semibold text-slate-200">{teams.length}</span> Teams
      </span>
      <span class="inline-flex items-center gap-1.5 text-xs text-slate-400 bg-slate-800/60 border border-slate-700/50 px-3 py-1.5 rounded-full">
        <span class="font-semibold text-slate-200">{nSims.toLocaleString()}</span> Simulations
      </span>
      {topName && (
        <span class="inline-flex items-center gap-1.5 text-xs text-amber-400 bg-amber-950/30 border border-amber-800/40 px-3 py-1.5 rounded-full">
          {topName} favored · {topChamp}
        </span>
      )}
    </div>
  </div>

  <!-- SECTION 2: Power Rankings — Top 8 -->
  {teams.length > 0 && (
    <section class="mb-14">
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-lg font-bold text-slate-100">Power Rankings</h2>
        <span class="text-[10px] uppercase tracking-widest text-slate-600">Championship odds</span>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
        {top8.map((t, i) => (
          <ForecastTeamCard
            rank={i + 1}
            team={t.team}
            qualify={t.qualify}
            r16={t.r16}
            qf={t.qf}
            sf={t.sf}
            final={t.final}
            champion={t.champion}
            champMax={champMax}
          />
        ))}
      </div>
    </section>
  )}

  <!-- SECTION 3: Championship Odds bar chart — top 16 -->
  {top16.length > 0 && (
    <section class="mb-14">
      <h2 class="text-lg font-bold text-slate-100 mb-5">Championship Odds</h2>
      <div class="space-y-2.5">
        {top16.map((t, i) => (
          <div class="flex items-center gap-3">
            <span class="text-slate-600 text-xs font-mono tabular-nums w-6 shrink-0 text-right">{i + 1}</span>
            <span class="text-slate-300 text-sm w-32 sm:w-40 truncate shrink-0">{formatTeamName(t.team)}</span>
            <div class="flex-1 h-6 bg-slate-800/60 rounded overflow-hidden">
              <div
                class={i < 3 ? 'h-full bg-amber-600/60 rounded' : 'h-full bg-blue-700/60 rounded'}
                style={champBarW(t.champion)}
              />
            </div>
            <span class="text-sm font-semibold tabular-nums w-12 text-right shrink-0 text-blue-300">
              {formatPct(t.champion)}
            </span>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- SECTION 4: Qualification Outlook -->
  {teams.length > 0 && (
    <section class="mb-14">
      <h2 class="text-lg font-bold text-slate-100 mb-2">Qualification Outlook</h2>
      <p class="text-slate-600 text-sm mb-6">Projected likelihood of advancing from the group stage.</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Safe -->
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="w-2 h-2 rounded-full bg-emerald-500/70 shrink-0"></span>
            <h3 class="text-xs font-bold uppercase tracking-widest text-slate-500">Looking Strong</h3>
          </div>
          <div class="space-y-1.5">
            {safeFavorites.map(t => (
              <div class="flex items-center justify-between bg-slate-900/50 border border-slate-800/50 rounded-lg px-3 py-2">
                <span class="text-sm text-slate-300 truncate">{formatTeamName(t.team)}</span>
                <span class="text-xs font-semibold text-emerald-400 tabular-nums shrink-0 ml-2">{formatPct(t.qualify, 0)}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Contested -->
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="w-2 h-2 rounded-full bg-amber-500/70 shrink-0"></span>
            <h3 class="text-xs font-bold uppercase tracking-widest text-slate-500">In the Mix</h3>
          </div>
          <div class="space-y-1.5">
            {contested.map(t => (
              <div class="flex items-center justify-between bg-slate-900/50 border border-slate-800/50 rounded-lg px-3 py-2">
                <span class="text-sm text-slate-300 truncate">{formatTeamName(t.team)}</span>
                <span class="text-xs font-semibold text-amber-400 tabular-nums shrink-0 ml-2">{formatPct(t.qualify, 0)}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Longshots -->
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="w-2 h-2 rounded-full bg-slate-600 shrink-0"></span>
            <h3 class="text-xs font-bold uppercase tracking-widest text-slate-500">Long Shots</h3>
          </div>
          <div class="space-y-1.5">
            {longshots.map(t => (
              <div class="flex items-center justify-between bg-slate-900/50 border border-slate-800/50 rounded-lg px-3 py-2">
                <span class="text-sm text-slate-500 truncate">{formatTeamName(t.team)}</span>
                <span class="text-xs font-semibold text-slate-500 tabular-nums shrink-0 ml-2">{formatPct(t.qualify, 0)}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- SECTION 5: All Teams Explorer -->
  {teams.length > 0 && (
    <section class="mb-14">
      <div class="mb-4">
        <h2 class="text-lg font-bold text-slate-100 mb-1">Explore All Teams</h2>
        <p class="text-slate-600 text-sm mb-3">Full championship probability rankings, all 48 teams.</p>
        <div class="relative max-w-sm">
          <input
            id="team-explorer-search"
            type="search"
            placeholder="Search teams…"
            autocomplete="off"
            class="w-full bg-slate-900/60 border border-slate-700/60 text-slate-300 placeholder:text-slate-600 text-sm rounded-lg pl-3 pr-3 py-2 focus:outline-none focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2 focus-visible:ring-offset-[#06091A] focus-visible:border-slate-500 transition-colors"
          />
        </div>
      </div>
      <p id="explorer-empty" class="hidden text-sm text-slate-600 mt-2">No teams found.</p>
      <div class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-1.5" id="explorer-grid">
        {sorted.map((t, i) => (
          <div
            data-explorer-row
            data-team-key={`${t.team} ${formatTeamName(t.team)}`.toLowerCase()}
            class="flex items-center gap-3 bg-slate-900/40 border border-slate-800/50 rounded-lg px-3 py-2.5 hover:border-slate-700/60 transition-colors"
          >
            <span class="text-slate-600 text-xs font-mono tabular-nums w-6 text-right shrink-0">{i + 1}</span>
            <span class="text-sm text-slate-300 flex-1 truncate">{formatTeamName(t.team)}</span>
            <div class="hidden sm:flex items-center gap-3 text-[11px] tabular-nums text-slate-600 shrink-0">
              <span>R16 {formatPct(t.r16, 0)}</span>
              <span>QF {formatPct(t.qf, 0)}</span>
            </div>
            <span class="text-sm font-semibold text-blue-400 tabular-nums shrink-0 w-12 text-right">
              {formatPct(t.champion)}
            </span>
          </div>
        ))}
      </div>
    </section>
  )}

  <RelatedLinks links={[
    { href: '/bracket',     label: 'Knockout Bracket' },
    { href: '/paths',       label: 'Road to the Final' },
    { href: '/best-thirds', label: 'Bubble Watch' },
    { href: '/matches',     label: 'All Matches' },
  ]} />

  <TrustStrip nSims={nSims} goalsModel={goalsModel} />

</Layout>

<script>
  // @ts-nocheck
  var input = document.getElementById('team-explorer-search');
  var rows  = document.querySelectorAll('[data-explorer-row]');
  var empty = document.getElementById('explorer-empty');

  function applySearch(q) {
    q = q.toLowerCase().trim();
    var visible = 0;
    rows.forEach(function(row) {
      var key = row.getAttribute('data-team-key') || '';
      var show = !q || key.includes(q);
      row.hidden = !show;
      if (show) visible++;
    });
    if (empty) empty.hidden = !q || visible > 0;
  }

  if (input) {
    input.addEventListener('input', function(e) { applySearch(e.target.value); });
  }
</script>
