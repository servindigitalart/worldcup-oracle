---
import Layout from '../layouts/Layout.astro';
import { loadJson } from '../utils/load';
import { formatTeamName, formatPct, formatKickoff } from '../utils/format';
import type { Recommendation, RecommendationsSummary } from '../types';

const recs    = loadJson<Recommendation[]>('recommendations.json', []);
const summary = loadJson<RecommendationsSummary>('recommendations_summary.json', {
  generated_at: '',
  total_matches: 0,
  n_no_recommendation: 0,
  n_watch: 0,
  n_market_aligned: 0,
  n_model_gap_detected: 0,
  n_avoid: 0,
  n_actionable: 0,
  n_missing_market: 0,
  has_real_market_data: false,
  language_policy: { forbidden_terms: [], safe_terms: [] },
  disclaimer: '',
} as RecommendationsSummary);

const hasData = recs.length > 0;
const hasMarket = summary.has_real_market_data;

// Sort: model_gap_detected first, then watch, then market_aligned, then no_recommendation
const TYPE_ORDER: Record<string, number> = {
  model_gap_detected: 0,
  avoid:              1,
  watch:              2,
  market_aligned:     3,
  no_recommendation:  4,
};
const sorted = [...recs].sort((a, b) =>
  (TYPE_ORDER[a.recommendation_type] ?? 9) - (TYPE_ORDER[b.recommendation_type] ?? 9)
);

function typeBadgeClass(t: string): string {
  switch (t) {
    case 'model_gap_detected': return 'bg-blue-900/50 text-blue-300 border-blue-700/50';
    case 'watch':              return 'bg-amber-900/50 text-amber-300 border-amber-700/50';
    case 'market_aligned':     return 'bg-slate-800 text-slate-400 border-slate-600';
    case 'avoid':              return 'bg-red-900/50 text-red-300 border-red-700/50';
    default:                   return 'bg-slate-900 text-slate-500 border-slate-800';
  }
}

function typeLabel(t: string): string {
  switch (t) {
    case 'model_gap_detected': return 'Model gap detected';
    case 'watch':              return 'Watch';
    case 'market_aligned':     return 'Market-aligned';
    case 'avoid':              return 'Avoid';
    default:                   return 'No recommendation';
  }
}

function confidenceClass(c: string): string {
  switch (c) {
    case 'high':   return 'text-emerald-400';
    case 'medium': return 'text-amber-400';
    case 'low':    return 'text-slate-400';
    default:       return 'text-slate-600';
  }
}

function riskClass(r: string): string {
  switch (r) {
    case 'high':   return 'text-red-400';
    case 'medium': return 'text-amber-400';
    case 'low':    return 'text-slate-400';
    default:       return 'text-slate-600';
  }
}

function selectionLabel(s: string | null): string {
  if (!s) return '—';
  if (s === 'home_win') return 'Home win';
  if (s === 'away_win') return 'Away win';
  if (s === 'draw')     return 'Draw';
  return s;
}

function formatGap(gap: number | null): string {
  if (gap == null) return '—';
  const sign = gap >= 0 ? '+' : '';
  return `${sign}${(gap * 100).toFixed(1)}pp`;
}

function edgeConfidenceClass(ec: string): string {
  switch (ec) {
    case 'very_high': return 'bg-blue-900/60 text-blue-300 border-blue-700/50';
    case 'high':      return 'bg-indigo-900/50 text-indigo-300 border-indigo-700/50';
    case 'medium':    return 'bg-amber-900/40 text-amber-300 border-amber-700/40';
    case 'low':       return 'bg-slate-800 text-slate-400 border-slate-600';
    default:          return 'bg-slate-900 text-slate-600 border-slate-800';
  }
}

function edgeConfidenceLabel(ec: string): string {
  switch (ec) {
    case 'very_high': return 'Very High';
    case 'high':      return 'High';
    case 'medium':    return 'Medium';
    case 'low':       return 'Low';
    default:          return '—';
  }
}
---
<Layout title="Betting Signals" description="Model-market gap signals — educational only, not betting advice">
  <div class="space-y-8">

    <!-- Header -->
    <div>
      <h1 class="text-3xl font-bold text-slate-100">Betting Signals</h1>
      <p class="mt-2 text-slate-400 max-w-2xl">
        Educational probability signals only — not betting advice.
        Flags where the model and market differ on 1X2 outcomes.
        Most matches produce no signal. See <a href="/matches" class="text-blue-400 hover:text-blue-300">Matches</a> for multi-market signals.
      </p>
      <div class="mt-3 rounded-lg border border-amber-800/50 bg-amber-950/30 px-4 py-2.5 text-sm max-w-2xl">
        <p class="font-semibold text-amber-400">Disclaimer</p>
        <p class="mt-0.5 text-amber-300/80">
          A model-market gap is not evidence of value. Market odds may be more accurate than model
          probabilities. This project does not provide gambling advice.
        </p>
      </div>
    </div>

    <!-- No real market data banner -->
    {!hasMarket && (
      <div class="rounded-xl border border-slate-700 bg-slate-800/40 px-5 py-5">
        <p class="font-semibold text-slate-300">No real market odds available yet</p>
        <p class="mt-1 text-sm text-slate-500">
          Recommendations are limited until real odds are captured.
          Set <code class="text-slate-400">ODDS_API_KEY</code> and run{' '}
          <code class="text-slate-400">make ingest-odds &amp;&amp; make blend &amp;&amp; make recommendations</code>.
          All matches currently show <span class="text-slate-400">no recommendation</span> (missing market data).
        </p>
      </div>
    )}

    <!-- Summary cards -->
    {hasData && (
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
        {[
          { label: 'Total matches',       value: summary.total_matches,          cls: 'text-slate-200' },
          { label: 'Model gap detected',  value: summary.n_model_gap_detected,   cls: 'text-blue-400'  },
          { label: 'Watch',               value: summary.n_watch,                cls: 'text-amber-400' },
          { label: 'Market-aligned',      value: summary.n_market_aligned,       cls: 'text-slate-400' },
          { label: 'No recommendation',   value: summary.n_no_recommendation,    cls: 'text-slate-500' },
          { label: 'Actionable',          value: summary.n_actionable,           cls: summary.n_actionable > 0 ? 'text-blue-400' : 'text-slate-500' },
        ].map(card => (
          <div class="rounded-xl border border-slate-700 bg-slate-800/30 px-4 py-3 text-center">
            <p class:list={['text-2xl font-bold', card.cls]}>{card.value}</p>
            <p class="mt-1 text-xs text-slate-500">{card.label}</p>
          </div>
        ))}
      </div>
    )}

    <!-- No data state -->
    {!hasData && (
      <div class="rounded-xl border border-slate-700 bg-slate-800/40 px-5 py-6 text-center">
        <p class="text-lg font-semibold text-slate-300">No recommendation data found</p>
        <p class="mt-1 text-sm text-slate-500">
          Run <code class="text-slate-400">make recommendations &amp;&amp; make export-web</code> to generate.
        </p>
      </div>
    )}

    <!-- Recommendation table -->
    {sorted.length > 0 && (
      <div class="overflow-x-auto rounded-xl border border-slate-700">
        <table class="w-full text-xs min-w-[900px]">
          <thead>
            <tr class="bg-slate-800/70 text-slate-400 border-b border-slate-700">
              <th class="px-3 py-2.5 text-left font-medium">Match</th>
              <th class="px-3 py-2.5 text-left font-medium">Grp</th>
              <th class="px-3 py-2.5 text-left font-medium">Type</th>
              <th class="px-3 py-2.5 text-left font-medium">Selection</th>
              <th class="px-3 py-2.5 text-right font-medium">Model</th>
              <th class="px-3 py-2.5 text-right font-medium">Market</th>
              <th class="px-3 py-2.5 text-right font-medium">Gap</th>
              <th class="px-3 py-2.5 text-center font-medium">Edge</th>
              <th class="px-3 py-2.5 text-center font-medium">Confidence</th>
              <th class="px-3 py-2.5 text-center font-medium">Risk</th>
              <th class="px-3 py-2.5 text-left font-medium">Reason</th>
            </tr>
          </thead>
          <tbody>
            {sorted.map((rec) => (
              <tr class="border-b border-slate-700/40 last:border-0 hover:bg-slate-800/30 transition-colors">
                <td class="px-3 py-2.5">
                  <div class="font-medium text-slate-200">
                    {formatTeamName(rec.home_team)} <span class="text-slate-500">vs</span> {formatTeamName(rec.away_team)}
                  </div>
                  {rec.kickoff_at && (
                    <div class="text-slate-600 text-[11px] mt-0.5">{formatKickoff(rec.kickoff_at)}</div>
                  )}
                </td>
                <td class="px-3 py-2.5 text-slate-500 font-mono text-center">{rec.group}</td>
                <td class="px-3 py-2.5">
                  <span class:list={[
                    'inline-block px-2 py-0.5 rounded text-[11px] border whitespace-nowrap',
                    typeBadgeClass(rec.recommendation_type),
                  ]}>
                    {typeLabel(rec.recommendation_type)}
                  </span>
                </td>
                <td class="px-3 py-2.5 text-slate-400 whitespace-nowrap">
                  {selectionLabel(rec.selection)}
                </td>
                <td class="px-3 py-2.5 text-right text-slate-300 font-mono">
                  {rec.model_probability != null ? formatPct(rec.model_probability) : '—'}
                </td>
                <td class="px-3 py-2.5 text-right text-slate-300 font-mono">
                  {rec.market_probability != null ? formatPct(rec.market_probability) : '—'}
                </td>
                <td class:list={[
                  'px-3 py-2.5 text-right font-mono',
                  rec.model_market_gap != null && Math.abs(rec.model_market_gap) >= 0.08
                    ? 'text-blue-400'
                    : rec.model_market_gap != null && Math.abs(rec.model_market_gap) >= 0.04
                    ? 'text-amber-400'
                    : 'text-slate-500',
                ]}>
                  {formatGap(rec.model_market_gap)}
                </td>
                <td class="px-3 py-2.5 text-center">
                  {rec.edge_confidence && rec.edge_confidence !== 'none' ? (
                    <span class:list={[
                      'inline-block px-2 py-0.5 rounded text-[11px] border whitespace-nowrap',
                      edgeConfidenceClass(rec.edge_confidence),
                    ]}>
                      {edgeConfidenceLabel(rec.edge_confidence)}
                    </span>
                  ) : (
                    <span class="text-slate-700">—</span>
                  )}
                </td>
                <td class:list={['px-3 py-2.5 text-center capitalize', confidenceClass(rec.confidence)]}>
                  {rec.confidence}
                </td>
                <td class:list={['px-3 py-2.5 text-center capitalize', riskClass(rec.risk_label)]}>
                  {rec.risk_label}
                </td>
                <td class="px-3 py-2.5 text-slate-500 max-w-xs">
                  <p class="line-clamp-2">{rec.reason}</p>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

    <!-- Language policy / footer -->
    <div class="text-xs text-slate-700 space-y-1 border-t border-slate-800 pt-4">
      <p class="font-semibold text-slate-600">Language policy</p>
      <p>This page never uses: guaranteed · lock · sure bet · free money · profit · must bet · high certainty.</p>
      <p>Probability signals are for educational use only. Not financial advice.</p>
    </div>

  </div>
</Layout>
