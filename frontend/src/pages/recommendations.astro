---
import Layout from '../layouts/Layout.astro';
import TopSignalCard from '../components/TopSignalCard.astro';
import SignalFeedCard from '../components/SignalFeedCard.astro';
import TrustStrip from '../components/TrustStrip.astro';
import RelatedLinks from '../components/RelatedLinks.astro';
import { loadJson } from '../utils/load';
import { formatTeamName, formatPct, formatKickoff } from '../utils/format';
import type {
  Recommendation,
  RecommendationsSummary,
  BlendedPrediction,
  FixtureScheduleEntry,
  SimSummary,
} from '../types';

// ── Data loading ──────────────────────────────────────────────────────────────
const recs    = loadJson<Recommendation[]>('recommendations.json', []);
const summary = loadJson<RecommendationsSummary | null>('recommendations_summary.json', null);
const bp      = loadJson<BlendedPrediction[]>('blended_predictions.json', []);
const sched   = loadJson<Record<string, FixtureScheduleEntry>>('fixture_schedule.json', {});
const sim     = loadJson<SimSummary | null>('sim_summary.json', null);

const hasMarket = summary?.has_real_market_data ?? false;
const nSignals  = summary?.n_actionable ?? 0;
const nGap      = summary?.n_model_gap_detected ?? 0;

// ── Build enriched match list ─────────────────────────────────────────────────
interface EnrichedMatch {
  match_id: string;
  home_team: string;
  away_team: string;
  group: string;
  blend_home: number;
  blend_draw: number;
  blend_away: number;
  kickoff_at: string | null;
  venue: string | null;
  city: string | null;
  signalType: 'model_gap_detected' | 'watch' | 'avoid' | 'model_only';
  reason: string | null;
  maxProb: number;
}

function getSchedule(home: string, away: string): FixtureScheduleEntry | null {
  return sched[`${home}_vs_${away}`] ?? sched[`${away}_vs_${home}`] ?? null;
}

const recByMatch: Record<string, Recommendation> = {};
for (const r of recs) recByMatch[r.match_id] = r;

const enriched: EnrichedMatch[] = bp.map((m) => {
  const fix = getSchedule(m.home_team, m.away_team);
  const rec = recByMatch[m.match_id];
  const rt  = rec?.recommendation_type ?? 'no_recommendation';
  const signalType: EnrichedMatch['signalType'] =
    rt === 'model_gap_detected' ? 'model_gap_detected' :
    rt === 'watch'              ? 'watch'              :
    rt === 'avoid'              ? 'avoid'              : 'model_only';

  return {
    ...m,
    kickoff_at: fix?.kickoff_at ?? null,
    venue:      fix?.venue      ?? null,
    city:       fix?.city       ?? null,
    signalType,
    reason: rec?.reason ?? null,
    maxProb: Math.max(m.blend_home, m.blend_draw, m.blend_away),
  };
});

// Sort by kickoff ascending (no kickoff goes to end)
const allSorted = [...enriched].sort((a, b) => {
  if (!a.kickoff_at && !b.kickoff_at) return 0;
  if (!a.kickoff_at) return 1;
  if (!b.kickoff_at) return -1;
  return a.kickoff_at.localeCompare(b.kickoff_at);
});

// ── Filter group assignment ────────────────────────────────────────────────────
// "Strong" = real gap signal OR model probability ≥ 65%
// "Moderate" = 50–65%
// "Watch" = < 50% max probability  OR watch/avoid signal type
function assignFilterGroups(m: EnrichedMatch): string[] {
  const groups: string[] = ['all', 'model_only'];
  if (m.signalType === 'model_gap_detected') { groups.push('market_gap', 'strong'); return groups; }
  if (m.signalType === 'watch' || m.signalType === 'avoid') { groups.push('watch'); return groups; }
  if      (m.maxProb >= 0.65) groups.push('strong');
  else if (m.maxProb >= 0.50) groups.push('moderate');
  else                        groups.push('watch');
  return groups;
}

// Counts for filter pills
const counts: Record<string, number> = { all: 0, strong: 0, moderate: 0, watch: 0, market_gap: 0, model_only: 0 };
for (const m of allSorted) {
  for (const g of assignFilterGroups(m)) counts[g] = (counts[g] ?? 0) + 1;
}

// ── Signal level for badge ────────────────────────────────────────────────────
function badgeLevel(signalType: EnrichedMatch['signalType']): string {
  if (signalType === 'model_gap_detected') return 'strong_signal';
  if (signalType === 'watch')              return 'watch';
  if (signalType === 'avoid')              return 'avoid';
  return 'model_probability_only';
}

// ── Top 5 by model probability (from all matches, sorted by decisiveness) ─────
const topFive = [...allSorted]
  .sort((a, b) => b.maxProb - a.maxProb)
  .slice(0, 5);

// ── Model highlights ──────────────────────────────────────────────────────────
const strongest    = topFive[0] ?? null;
const mostBalanced = [...allSorted].sort((a, b) => a.maxProb - b.maxProb)[0] ?? null;
const highestDraw  = [...allSorted].sort((a, b) => b.blend_draw - a.blend_draw)[0] ?? null;

// ── Filter pill options (defined here to avoid generic angle-brackets in JSX) ─
interface FilterOption { key: string; label: string; count: number }
const filterOptions: FilterOption[] = [
  { key: 'all',        label: 'All',        count: counts.all        ?? 0 },
  { key: 'strong',     label: 'Favorites',  count: counts.strong     ?? 0 },
  { key: 'moderate',   label: 'Moderate',   count: counts.moderate   ?? 0 },
  { key: 'watch',      label: 'Watch',      count: counts.watch      ?? 0 },
  { key: 'market_gap', label: 'Market Gap', count: counts.market_gap ?? 0 },
  { key: 'model_only', label: 'Model Only', count: counts.model_only ?? 0 },
];

// ── Helper ────────────────────────────────────────────────────────────────────
function labelDominant(m: EnrichedMatch): string {
  if (m.blend_home >= m.blend_draw && m.blend_home >= m.blend_away)
    return formatTeamName(m.home_team);
  if (m.blend_away > m.blend_home && m.blend_away >= m.blend_draw)
    return formatTeamName(m.away_team);
  return 'Draw';
}
---

<Layout
  title="Betting Signals"
  description="Model probability signals and market gap analysis for every 2026 World Cup fixture. Educational only — not betting advice."
>
  <div class="space-y-14">

    <!-- ══════════════════ SECTION 1: HERO ══════════════════════════════════ -->
    <section>
      <p class="text-xs font-semibold uppercase tracking-widest text-cyan-600 mb-3">
        World Cup 2026 · Betting Intelligence
      </p>
      <h1 class="text-3xl sm:text-4xl font-bold text-slate-100 tracking-tight leading-tight mb-4">
        Today's Betting Intelligence
      </h1>
      <p class="text-slate-400 text-base leading-relaxed max-w-2xl mb-8">
        We surface matches where the model sees unusually decisive probabilities, and —
        once market odds are available — where those probabilities diverge from bookmaker prices.
        Educational only.
      </p>

      <!-- Stat pills -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="rounded-lg border border-slate-800/70 bg-slate-900/50 px-4 py-3">
          <div class="text-xl font-bold text-slate-100">{bp.length}</div>
          <div class="text-[11px] text-slate-500 mt-0.5">Matches analysed</div>
        </div>
        <div class="rounded-lg border border-slate-800/70 bg-slate-900/50 px-4 py-3">
          <div class:list={['text-xl font-bold', nSignals > 0 ? 'text-cyan-400' : 'text-slate-100']}>
            {nSignals}
          </div>
          <div class="text-[11px] text-slate-500 mt-0.5">Actionable signals</div>
        </div>
        <div class="rounded-lg border border-slate-800/70 bg-slate-900/50 px-4 py-3">
          <div class:list={['text-xl font-bold', nGap > 0 ? 'text-cyan-400' : 'text-slate-100']}>
            {nGap}
          </div>
          <div class="text-[11px] text-slate-500 mt-0.5">Market gap signals</div>
        </div>
        <div class="rounded-lg border border-slate-800/70 bg-slate-900/50 px-4 py-3">
          <div class="text-xl font-bold text-slate-100">
            {hasMarket ? ((summary?.n_actionable ?? 0) + ' live') : 'Connecting'}
          </div>
          <div class="text-[11px] text-slate-500 mt-0.5">Market odds status</div>
        </div>
      </div>
    </section>

    <!-- Market data status notice -->
    {!hasMarket && (
      <section class="rounded-xl border border-slate-800/60 bg-slate-900/30 px-5 py-4 flex items-start gap-3">
        <div class="w-2 h-2 rounded-full bg-amber-500/60 mt-1.5 shrink-0" />
        <div>
          <p class="text-sm font-medium text-slate-300 mb-1">Market odds not yet connected</p>
          <p class="text-sm text-slate-500 leading-relaxed">
            Signals shown are based on model probabilities only. Market gap analysis — where
            the model and bookmaker odds disagree — will appear once odds are captured for
            these matches. All probabilities below are Elo + Dixon-Coles model outputs.
          </p>
        </div>
      </section>
    )}

    <!-- ══════════════════ SECTION 5: MODEL HIGHLIGHTS ══════════════════════ -->
    <!-- (Placed before Top Signals when market data absent — most useful content first) -->
    <section>
      <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-4">
        Model Highlights
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">

        {strongest && (
          <a
            href={`/match/${strongest.match_id}`}
            class="group rounded-xl border border-slate-800/70 bg-slate-900/50 hover:border-slate-700 transition-colors px-4 py-4"
          >
            <div class="text-[10px] text-slate-600 uppercase tracking-wider mb-2">Strongest favorite</div>
            <div class="text-2xl font-bold text-blue-300 tabular-nums mb-1">
              {formatPct(strongest.maxProb)}
            </div>
            <div class="text-xs text-slate-400 truncate">{labelDominant(strongest)}</div>
            <div class="text-[11px] text-slate-600 mt-0.5 truncate">
              {formatTeamName(strongest.home_team)} vs {formatTeamName(strongest.away_team)}
            </div>
            <div class="text-[11px] text-blue-500 group-hover:text-blue-400 mt-2 transition-colors">
              View →
            </div>
          </a>
        )}

        {mostBalanced && (
          <a
            href={`/match/${mostBalanced.match_id}`}
            class="group rounded-xl border border-slate-800/70 bg-slate-900/50 hover:border-slate-700 transition-colors px-4 py-4"
          >
            <div class="text-[10px] text-slate-600 uppercase tracking-wider mb-2">Most balanced</div>
            <div class="text-2xl font-bold text-slate-200 tabular-nums mb-1">
              {formatPct(mostBalanced.blend_home, 0)} / {formatPct(mostBalanced.blend_away, 0)}
            </div>
            <div class="text-xs text-slate-400 truncate">
              {formatTeamName(mostBalanced.home_team)} vs {formatTeamName(mostBalanced.away_team)}
            </div>
            <div class="text-[11px] text-slate-600 mt-0.5">Closest to even split</div>
            <div class="text-[11px] text-blue-500 group-hover:text-blue-400 mt-2 transition-colors">
              View →
            </div>
          </a>
        )}

        {highestDraw && (
          <a
            href={`/match/${highestDraw.match_id}`}
            class="group rounded-xl border border-slate-800/70 bg-slate-900/50 hover:border-slate-700 transition-colors px-4 py-4"
          >
            <div class="text-[10px] text-slate-600 uppercase tracking-wider mb-2">Highest draw prob</div>
            <div class="text-2xl font-bold text-slate-300 tabular-nums mb-1">
              {formatPct(highestDraw.blend_draw)}
            </div>
            <div class="text-xs text-slate-400 truncate">
              {formatTeamName(highestDraw.home_team)} vs {formatTeamName(highestDraw.away_team)}
            </div>
            <div class="text-[11px] text-slate-600 mt-0.5">Draw probability</div>
            <div class="text-[11px] text-blue-500 group-hover:text-blue-400 mt-2 transition-colors">
              View →
            </div>
          </a>
        )}

        <div class="rounded-xl border border-slate-800/70 bg-slate-900/50 px-4 py-4">
          <div class="text-[10px] text-slate-600 uppercase tracking-wider mb-2">Matches with data</div>
          <div class="text-2xl font-bold text-slate-100 tabular-nums mb-1">{bp.length}</div>
          <div class="text-xs text-slate-400">Group stage</div>
          <div class="text-[11px] text-slate-600 mt-0.5">{counts.strong ?? 0} decisive favorites</div>
        </div>
      </div>
    </section>

    <!-- ══════════════════ SECTION 2: TOP SIGNALS ════════════════════════════ -->
    <section>
      <div class="flex items-baseline justify-between mb-4">
        <div>
          <h2 class="text-lg font-semibold text-slate-200">
            {hasMarket ? 'Top Signals' : 'Top Probability Signals'}
          </h2>
          <p class="text-xs text-slate-600 mt-0.5">
            {hasMarket
              ? 'Matches with the strongest model-market divergence'
              : 'Matches where the model has the highest probability convictions — model only, no market benchmark yet'}
          </p>
        </div>
      </div>

      {topFive.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {topFive.map((m, i) => (
            <div class:list={[i === 0 ? 'sm:col-span-2' : '']}>
              <TopSignalCard
                match_id={m.match_id}
                homeLabel={formatTeamName(m.home_team)}
                awayLabel={formatTeamName(m.away_team)}
                group={m.group}
                kickoffFormatted={m.kickoff_at ? formatKickoff(m.kickoff_at) : null}
                venue={m.venue}
                city={m.city}
                pHome={m.blend_home}
                pDraw={m.blend_draw}
                pAway={m.blend_away}
                signalLevel={badgeLevel(m.signalType)}
                hasMarketData={hasMarket}
                reason={null}
              />
            </div>
          ))}
        </div>
      ) : (
        <div class="rounded-xl border border-slate-800/50 bg-slate-900/30 px-5 py-8 text-center">
          <p class="text-slate-400 font-medium mb-2">No match data yet</p>
          <p class="text-sm text-slate-600">
            Match probabilities will appear here once the model pipeline runs.
          </p>
        </div>
      )}
    </section>

    <!-- ══════════════════ SECTION 3: SIGNAL FEED ════════════════════════════ -->
    <section id="signal-feed">
      <div class="flex items-baseline justify-between mb-4 gap-4 flex-wrap">
        <h2 class="text-lg font-semibold text-slate-200">Signal Feed</h2>
        <p class="text-xs text-slate-600">{allSorted.length} matches · sorted by kickoff</p>
      </div>

      <!-- Filter bar -->
      <div class="flex gap-2 overflow-x-auto pb-2 mb-5 -mx-4 px-4 sm:mx-0 sm:px-0">
        {filterOptions.map(({ key, label, count }) => (
          <button
            data-filter-btn={key}
            class:list={[
              'filter-pill text-xs px-3.5 py-1.5 rounded-full border transition-colors cursor-pointer whitespace-nowrap shrink-0 flex items-center gap-1.5',
              key === 'all'
                ? 'fp-active border-blue-700/50 bg-blue-900/30 text-blue-300'
                : 'fp-inactive border-slate-700 text-slate-400 hover:text-slate-200 hover:border-slate-600',
            ]}
          >
            {label}
            <span class:list={['tabular-nums', key === 'all' ? 'text-blue-500' : 'text-slate-600']}>
              {count}
            </span>
          </button>
        ))}
      </div>

      <!-- Feed grid -->
      {allSorted.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3" id="feed-grid">
          {allSorted.map((m) => (
            <div data-card data-filter-group={assignFilterGroups(m).join(' ')}>
              <SignalFeedCard
                match_id={m.match_id}
                homeLabel={formatTeamName(m.home_team)}
                awayLabel={formatTeamName(m.away_team)}
                group={m.group}
                kickoffFormatted={m.kickoff_at ? formatKickoff(m.kickoff_at) : null}
                city={m.city}
                pHome={m.blend_home}
                pDraw={m.blend_draw}
                pAway={m.blend_away}
                signalLevel={badgeLevel(m.signalType)}
                hasMarketData={hasMarket}
              />
            </div>
          ))}
        </div>
      ) : (
        <div class="rounded-xl border border-slate-800/50 bg-slate-900/30 px-5 py-8 text-center">
          <p class="text-slate-500">No match data available.</p>
        </div>
      )}

      <!-- Feed empty state (shown by JS when filter has no results) -->
      <div id="feed-empty" hidden class="rounded-xl border border-slate-800/50 bg-slate-900/30 px-5 py-8 text-center mt-3">
        <p class="text-slate-400 font-medium mb-2">No matches for this filter</p>
        <p class="text-sm text-slate-600 max-w-sm mx-auto">
          {nGap === 0
            ? 'Market gap signals require real market odds. Connect odds data to populate this filter.'
            : 'No matches match this filter — try "All" to see every match.'}
        </p>
      </div>
    </section>

    <!-- ══════════════════ SECTION 4: MARKET GAP SIGNALS ════════════════════ -->
    <section>
      <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-3">
        Market Gap Signals
      </h2>
      {nGap > 0 ? (
        <p class="text-sm text-slate-500">
          {nGap} market gap signal{nGap !== 1 ? 's' : ''} detected above.
        </p>
      ) : (
        <div class="rounded-xl border border-slate-800/50 bg-slate-900/30 p-6 sm:p-8">
          <div class="max-w-xl">
            <p class="text-sm font-medium text-slate-300 mb-3">
              No market-gap signals available yet
            </p>
            <p class="text-sm text-slate-500 leading-relaxed mb-4">
              Market gap signals highlight matches where the model's probability differs
              meaningfully from bookmaker odds — suggesting the market may be mispricing
              a particular outcome. These signals require real market odds as a benchmark.
            </p>
            <p class="text-sm text-slate-500 leading-relaxed">
              Current coverage: 0 of {bp.length} matches have market odds connected.
              The model is generating probabilities for all matches, but there is no market
              benchmark to compare against yet.
            </p>
          </div>
        </div>
      )}
    </section>

    <!-- ══════════════════ SECTION 6: HOW SIGNALS WORK ═════════════════════ -->
    <section class="rounded-xl border border-slate-800/60 bg-slate-900/30 p-5 sm:p-6">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-5">
        How Signals Work
      </h2>

      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3 sm:gap-0 mb-5">
        {[
          { step: '1', label: 'Model runs',      desc: 'Elo + Dixon-Coles generates match probabilities' },
          { step: '2', label: 'Market captured', desc: 'Bookmaker odds are converted to implied probabilities' },
          { step: '3', label: 'Gap computed',    desc: 'Model vs market difference is measured per selection' },
          { step: '4', label: 'Signal rated',    desc: 'Confidence + risk labels applied based on gap size' },
          { step: '5', label: 'Analysis',        desc: 'View the full breakdown on the match page' },
        ].map((s, i, arr) => (
          <div class="flex sm:flex-col items-center gap-3 flex-1">
            <div class="flex sm:flex-col items-center gap-2 flex-1 sm:text-center">
              <div class="w-7 h-7 rounded-full border border-slate-700 bg-slate-800 flex items-center justify-center text-xs font-bold text-slate-300 shrink-0">
                {s.step}
              </div>
              <div>
                <div class="text-xs font-semibold text-slate-300">{s.label}</div>
                <div class="text-[11px] text-slate-600 mt-0.5 leading-tight">{s.desc}</div>
              </div>
            </div>
            {i < arr.length - 1 && (
              <div class="hidden sm:block text-slate-700 text-xs mx-1 self-center">→</div>
            )}
          </div>
        ))}
      </div>

      <div class="flex items-center gap-3 border-t border-slate-800/50 pt-4">
        <a
          href="/methodology"
          class="text-sm text-blue-400 hover:text-blue-300 transition-colors"
        >
          Full methodology →
        </a>
        <span class="text-slate-700">·</span>
        <a
          href="/calibration"
          class="text-sm text-slate-500 hover:text-slate-300 transition-colors"
        >
          Model calibration →
        </a>
      </div>
    </section>

    <!-- Cross-links -->
    <RelatedLinks links={[
      { href: '/matches',    label: 'Explore All Matches' },
      { href: '/tournament', label: 'World Cup Forecast' },
      { href: '/bracket',    label: 'Knockout Bracket' },
    ]} />

    <!-- Trust strip -->
    {sim && (
      <section class="pb-4">
        <TrustStrip nSims={sim.n_sims} goalsModel={sim.goals_model_version} />
      </section>
    )}

  </div>
</Layout>

<style is:global>
  .fp-active {
    background-color: rgba(23, 37, 84, 0.4);
    color: rgb(147, 197, 253);
    border-color: rgba(59, 130, 246, 0.4);
  }
  .fp-inactive {
    color: rgb(100, 116, 139);
    border-color: rgb(51, 65, 85);
  }
  .fp-inactive:hover {
    color: rgb(203, 213, 225);
    border-color: rgb(71, 85, 105);
  }
</style>

<script>
  const buttons   = document.querySelectorAll('[data-filter-btn]');
  const cards     = document.querySelectorAll('[data-card]');
  const feedEmpty = document.getElementById('feed-empty');

  function applyFilter(filter) {
    let visible = 0;
    cards.forEach((card) => {
      const groups = (card.getAttribute('data-filter-group') || '').split(' ');
      const show = filter === 'all' || groups.includes(filter);
      card.hidden = !show;
      if (show) visible++;
    });
    if (feedEmpty) feedEmpty.hidden = visible > 0;
  }

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter-btn') || 'all';
      buttons.forEach((b) => {
        b.classList.remove('fp-active');
        b.classList.add('fp-inactive');
      });
      btn.classList.remove('fp-inactive');
      btn.classList.add('fp-active');
      applyFilter(filter);
    });
  });
</script>
