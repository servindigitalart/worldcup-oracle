---
const links = [
  { href: '/',                 label: 'Home'             },
  { href: '/matches',          label: 'Matches'          },
  { href: '/recommendations',  label: 'Signals'          },
  { href: '/tournament',       label: 'Tournament'       },
  { href: '/standings',        label: 'Standings'        },
  { href: '/bracket',          label: 'Bracket'          },
  { href: '/probabilities',    label: 'Probabilities'    },
  { href: '/paths',            label: 'Paths'            },
  { href: '/best-thirds',      label: 'Best Thirds'      },
  { href: '/model',            label: 'Model'            },
  { href: '/market',           label: 'Market'           },
  { href: '/calibration',      label: 'Calibration'      },
  { href: '/methodology',      label: 'Methodology'      },
  { href: '/data',             label: 'Data'             },
  { href: '/performance',      label: 'Performance'      },
  { href: '/history',          label: 'History'          },
  { href: '/market-history',   label: 'Mkt History'      },
  { href: '/status',           label: 'Status'           },
];
const { pathname } = Astro.url;
---
<nav class="sticky top-0 z-10 bg-slate-900/95 backdrop-blur border-b border-slate-800">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center h-13 gap-6">
    <a href="/" class="font-semibold text-white text-sm tracking-tight shrink-0">
      WC 2026 Oracle
    </a>
    <div class="flex gap-0.5 overflow-x-auto">
      {links.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'px-3 py-1.5 rounded text-sm whitespace-nowrap transition-colors',
            pathname === href
              ? 'bg-slate-700 text-white font-medium'
              : 'text-slate-400 hover:text-white hover:bg-slate-800',
          ]}
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</nav>
