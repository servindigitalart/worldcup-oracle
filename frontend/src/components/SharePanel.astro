---
interface Props {
  summaryText: string;
}
const { summaryText } = Astro.props;
---

<div class="flex items-center gap-2.5 flex-wrap">
  <button
    id="share-copy-link"
    type="button"
    class="inline-flex items-center gap-1.5 text-sm text-slate-300 bg-slate-800/60 border border-slate-700/60 hover:border-slate-600 hover:text-slate-100 px-3.5 py-1.5 rounded-lg transition-[border-color,color] duration-150 ease-out active:scale-[0.98] active:transition-none"
  >
    <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
    </svg>
    Copy link
  </button>

  <button
    id="share-copy-summary"
    type="button"
    class="inline-flex items-center gap-1.5 text-sm text-slate-300 bg-slate-800/60 border border-slate-700/60 hover:border-slate-600 hover:text-slate-100 px-3.5 py-1.5 rounded-lg transition-[border-color,color] duration-150 ease-out active:scale-[0.98] active:transition-none"
  >
    <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0 0 13.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 0 1-.75.75H9a.75.75 0 0 1-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 0 1 1.927-.184" />
    </svg>
    Copy summary
  </button>

  <span
    id="share-feedback"
    class="text-xs text-emerald-400 transition-opacity duration-300 opacity-0 pointer-events-none"
    aria-live="polite"
    aria-atomic="true"
  >
    Copied!
  </span>
</div>

<script define:vars={{ summaryText }}>
  // @ts-nocheck
  function copyText(text) {
    if (typeof navigator !== 'undefined' && navigator.clipboard && navigator.clipboard.writeText) {
      return navigator.clipboard.writeText(text);
    }
    var el = document.createElement('textarea');
    el.value = text;
    el.style.cssText = 'position:fixed;opacity:0;pointer-events:none;top:0;left:0;width:1px;height:1px';
    document.body.appendChild(el);
    el.focus();
    el.select();
    try { document.execCommand('copy'); } catch (_) {}
    document.body.removeChild(el);
    return Promise.resolve();
  }

  function showFeedback() {
    var fb = document.getElementById('share-feedback');
    if (!fb) return;
    fb.style.opacity = '1';
    setTimeout(function () { fb.style.opacity = '0'; }, 2000);
  }

  var linkBtn    = document.getElementById('share-copy-link');
  var summaryBtn = document.getElementById('share-copy-summary');

  if (linkBtn) {
    linkBtn.addEventListener('click', function () {
      copyText(window.location.href).then(showFeedback).catch(function () {});
    });
  }

  if (summaryBtn) {
    summaryBtn.addEventListener('click', function () {
      copyText(summaryText + '\n' + window.location.href).then(showFeedback).catch(function () {});
    });
  }
</script>
