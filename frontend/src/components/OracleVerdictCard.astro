---
import SignalBadge from './SignalBadge.astro';
import { formatPct, formatOdds } from '../utils/format';

interface Props {
  signalLevel: 'model_gap_detected' | 'watch' | 'avoid' | 'model_only' | 'none';
  selectionLabel: string | null;
  modelProbability: number | null;
  marketProbability: number | null;
  gap: number | null;
  confidence: string | null;
  risk: string | null;
  reason: string | null;
  hasMarketData: boolean;
}

const {
  signalLevel,
  selectionLabel,
  modelProbability,
  marketProbability,
  gap,
  confidence,
  risk,
  reason,
  hasMarketData,
} = Astro.props;

const HEADLINES: Record<string, string> = {
  model_gap_detected: `Market gap detected on ${selectionLabel}`,
  watch:               `Worth a closer look: ${selectionLabel}`,
  avoid:               `Avoid: model and market disagree sharply`,
  model_only:          `Model favors ${selectionLabel}`,
  none:                'No clear betting signal yet',
};

const badgeLevel =
  signalLevel === 'model_gap_detected' ? 'strong_signal' :
  signalLevel === 'watch'              ? 'watch' :
  signalLevel === 'avoid'              ? 'avoid' :
  signalLevel === 'model_only'         ? 'model_probability_only' :
                                          'no_signal';

const headline = HEADLINES[signalLevel] ?? HEADLINES.none;
const isReal = signalLevel === 'model_gap_detected' || signalLevel === 'watch' || signalLevel === 'avoid';

const confClass: Record<string, string> = {
  high: 'text-emerald-400', medium: 'text-amber-400', low: 'text-slate-400', unknown: 'text-slate-600',
};
const riskClass: Record<string, string> = {
  high: 'text-red-400', medium: 'text-amber-400', low: 'text-slate-400', unknown: 'text-slate-600',
};
---

<div class="relative overflow-hidden rounded-2xl border border-blue-900/40 bg-gradient-to-br from-blue-950/60 via-slate-900/80 to-slate-900/60 p-6 sm:p-8">
  <div class="relative">
    <div class="flex items-center justify-between mb-4 gap-3 flex-wrap">
      <span class="text-[11px] font-semibold uppercase tracking-widest text-cyan-600">
        Oracle Verdict
      </span>
      <SignalBadge level={badgeLevel} size="md" />
    </div>

    <h2 class="text-xl sm:text-2xl font-bold text-slate-100 tracking-tight mb-4">
      {headline}
    </h2>

    {!hasMarketData && (
      <p class="text-sm text-slate-500 mb-5 max-w-xl">
        Market benchmark unavailable — this is model probability only.
        There is no betting market to compare against yet.
      </p>
    )}

    {selectionLabel && (
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-5">
        <div>
          <div class="text-[11px] text-slate-500 uppercase tracking-wider mb-1">Model probability</div>
          <div class="text-xl font-bold text-slate-100">{formatPct(modelProbability)}</div>
        </div>
        <div>
          <div class="text-[11px] text-slate-500 uppercase tracking-wider mb-1">Fair odds</div>
          <div class="text-xl font-bold text-slate-300">{formatOdds(modelProbability)}</div>
        </div>
        {hasMarketData && marketProbability != null ? (
          <div>
            <div class="text-[11px] text-slate-500 uppercase tracking-wider mb-1">Market probability</div>
            <div class="text-xl font-bold text-slate-300">{formatPct(marketProbability)}</div>
          </div>
        ) : (
          <div>
            <div class="text-[11px] text-slate-500 uppercase tracking-wider mb-1">Market probability</div>
            <div class="text-xl font-bold text-slate-700">—</div>
          </div>
        )}
        {gap != null ? (
          <div>
            <div class="text-[11px] text-slate-500 uppercase tracking-wider mb-1">Market gap</div>
            <div class:list={['text-xl font-bold', gap > 0 ? 'text-cyan-400' : 'text-red-400']}>
              {gap > 0 ? '+' : ''}{formatPct(gap, 1)}
            </div>
          </div>
        ) : (
          <div>
            <div class="text-[11px] text-slate-500 uppercase tracking-wider mb-1">Market gap</div>
            <div class="text-xl font-bold text-slate-700">—</div>
          </div>
        )}
      </div>
    )}

    {isReal && (confidence || risk) && (
      <div class="flex items-center gap-5 mb-4 text-sm">
        {confidence && (
          <div>
            <span class="text-slate-500">Confidence: </span>
            <span class:list={['font-semibold capitalize', confClass[confidence] ?? 'text-slate-400']}>{confidence}</span>
          </div>
        )}
        {risk && (
          <div>
            <span class="text-slate-500">Risk: </span>
            <span class:list={['font-semibold capitalize', riskClass[risk] ?? 'text-slate-400']}>{risk}</span>
          </div>
        )}
      </div>
    )}

    {reason && (
      <p class="text-sm text-slate-400 leading-relaxed border-t border-slate-800/60 pt-4">
        {reason}
      </p>
    )}
  </div>
</div>
