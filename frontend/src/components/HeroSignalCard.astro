---
import SignalBadge from './SignalBadge.astro';

interface MatchSpotlight {
  match_id: string;
  home_team: string;
  away_team: string;
  group: string;
  kickoff_at: string | null;
  city: string | null;
  venue: string | null;
  blend_home: number;
  blend_draw: number;
  blend_away: number;
  has_market_data: boolean;
}

interface Props {
  match: MatchSpotlight;
  homeLabel: string;
  awayLabel: string;
  kickoffFormatted: string;
}

const { match, homeLabel, awayLabel, kickoffFormatted } = Astro.props;

const home  = match.blend_home;
const draw  = match.blend_draw;
const away  = match.blend_away;

// Determine dominant outcome and signal level
const max = Math.max(home, draw, away);
const isStrong = max >= 0.65;
const isMedium = max >= 0.55;
const signalLevel = isStrong ? 'strong_signal' : isMedium ? 'moderate_signal' : 'model_probability_only';

let dominant = 'home_win', dominantLabel = `${homeLabel} to win`, dominantPct = home;
if (draw >= home && draw >= away) {
  dominant = 'draw'; dominantLabel = 'Match ends in a draw'; dominantPct = draw;
} else if (away > home) {
  dominant = 'away_win'; dominantLabel = `${awayLabel} to win`; dominantPct = away;
}

const pctFmt = (v: number) => (v * 100).toFixed(1) + '%';
const barPct = (v: number) => Math.max(v * 100, 1).toFixed(2) + '%';
---

<div class="relative overflow-hidden rounded-2xl border border-blue-900/40 bg-gradient-to-br from-blue-950/60 via-slate-900/80 to-slate-900/60 p-6 sm:p-8">
  <!-- Background accent -->
  <div class="absolute inset-0 bg-gradient-to-br from-cyan-950/10 to-transparent pointer-events-none" />

  <div class="relative">
    <!-- Label row -->
    <div class="flex items-center justify-between mb-5">
      <div class="flex items-center gap-2">
        <span class="text-[11px] font-semibold uppercase tracking-widest text-cyan-600">
          Model Spotlight
        </span>
        <span class="text-slate-700">·</span>
        <span class="text-[11px] text-slate-500 uppercase tracking-wider">Group {match.group}</span>
      </div>
      <SignalBadge level={signalLevel} size="md" />
    </div>

    <!-- Match header -->
    <div class="mb-6">
      <div class="flex items-center justify-between gap-4">
        <div class="flex-1 min-w-0">
          <h2 class="text-2xl sm:text-3xl font-bold text-slate-100 tracking-tight truncate">
            {homeLabel}
          </h2>
          <div class="text-sm text-slate-500 mt-0.5">{pctFmt(home)} win probability</div>
        </div>

        <div class="shrink-0 text-center">
          <div class="text-xs font-semibold text-slate-600 uppercase tracking-wider mb-1">vs</div>
          <div class="text-xs text-slate-600">{pctFmt(draw)} draw</div>
        </div>

        <div class="flex-1 min-w-0 text-right">
          <h2 class="text-2xl sm:text-3xl font-bold text-slate-100 tracking-tight truncate">
            {awayLabel}
          </h2>
          <div class="text-sm text-slate-500 mt-0.5">{pctFmt(away)} win probability</div>
        </div>
      </div>

      <!-- Kickoff meta -->
      <div class="mt-3 text-xs text-slate-500 flex items-center gap-2 flex-wrap">
        <span>{kickoffFormatted}</span>
        {match.city && <><span class="text-slate-700">·</span><span>{match.city}</span></>}
        {match.venue && <><span class="text-slate-700">·</span><span class="text-slate-600">{match.venue}</span></>}
      </div>
    </div>

    <!-- Probability bar -->
    <div class="mb-5">
      <div class="flex h-9 rounded-lg overflow-hidden text-xs font-semibold">
        <div
          class="flex items-center justify-center bg-blue-700/80 text-blue-100 transition-all"
          style={`width:${barPct(home)}`}
        >
          {home >= 0.15 ? pctFmt(home) : ''}
        </div>
        <div
          class="flex items-center justify-center bg-slate-600/80 text-slate-300 transition-all"
          style={`width:${barPct(draw)}`}
        >
          {draw >= 0.15 ? pctFmt(draw) : ''}
        </div>
        <div
          class="flex items-center justify-center bg-rose-800/70 text-rose-200 transition-all"
          style={`width:${barPct(away)}`}
        >
          {away >= 0.15 ? pctFmt(away) : ''}
        </div>
      </div>
      <div class="flex justify-between text-[10px] text-slate-600 mt-1.5 px-0.5">
        <span>Home win</span>
        <span>Draw</span>
        <span>Away win</span>
      </div>
    </div>

    <!-- Signal insight + CTA -->
    <div class="flex items-start justify-between gap-4 flex-wrap">
      <div class="min-w-0">
        <div class="text-sm text-slate-300 font-medium">
          Model favors <span class="text-cyan-400">{dominantLabel}</span> at <span class="text-cyan-400">{pctFmt(dominantPct)}</span>
        </div>
        {!match.has_market_data && (
          <p class="text-xs text-slate-500 mt-1">
            Model probability only — market benchmark not yet connected
          </p>
        )}
      </div>
      <a
        href={`/match/${match.match_id}`}
        class="shrink-0 inline-flex items-center gap-1.5 rounded-lg bg-blue-600 hover:bg-blue-500 px-4 py-2 text-sm font-semibold text-white transition-colors"
      >
        Full analysis
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</div>
