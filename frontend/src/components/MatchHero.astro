---
interface Props {
  homeLabel: string;
  awayLabel: string;
  group: string;
  kickoffFormatted: string | null;
  venue: string | null;
  city: string | null;
  isOfficial: boolean;
}

const { homeLabel, awayLabel, group, kickoffFormatted, venue, city, isOfficial } = Astro.props;
---

<div class="space-y-3">
  <div class="flex items-center gap-2 flex-wrap">
    <span class="text-[11px] font-semibold uppercase tracking-widest text-slate-500">
      Group {group}
    </span>
    {isOfficial && (
      <span class="text-[10px] px-2 py-0.5 rounded border border-emerald-800/50 bg-emerald-950/40 text-emerald-400 font-medium">
        Official fixture
      </span>
    )}
  </div>

  <h1 class="flex items-center gap-3 sm:gap-5 flex-wrap">
    <span class="text-2xl sm:text-4xl font-bold text-slate-100 tracking-tight">{homeLabel}</span>
    <span class="text-sm sm:text-base text-slate-600 font-medium shrink-0">vs</span>
    <span class="text-2xl sm:text-4xl font-bold text-slate-100 tracking-tight">{awayLabel}</span>
  </h1>

  <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-slate-500">
    {kickoffFormatted && <span>{kickoffFormatted}</span>}
    {venue && (
      <>
        <span class="text-slate-700">·</span>
        <span>{venue}{city ? `, ${city}` : ''}</span>
      </>
    )}
  </div>
</div>
