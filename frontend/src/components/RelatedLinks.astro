---
interface NavLink {
  href: string;
  label: string;
}

interface Props {
  links: NavLink[];
  heading?: string;
}

const { links, heading = 'Continue Exploring' } = Astro.props;
---

<div class="rounded-xl border border-slate-800/50 bg-slate-900/30 px-4 py-4 mb-10">
  <h3 class="text-[10px] font-bold uppercase tracking-widest text-slate-600 mb-3">{heading}</h3>
  <div class="flex flex-wrap gap-2">
    {links.map(l => (
      <a
        href={l.href}
        class="text-xs text-slate-400 hover:text-slate-200 border border-slate-800/60 hover:border-slate-700 px-3 py-1.5 rounded-lg transition-colors"
      >
        {l.label} →
      </a>
    ))}
  </div>
</div>
