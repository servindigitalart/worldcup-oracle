---
import { formatTeamName, formatPct } from '../utils/format';

interface Props {
  rank: number;
  team: string;
  qualify: number;
  r16: number;
  qf: number;
  sf: number;
  final: number;
  champion: number;
  champMax: number;
}

const { rank, team, qualify, r16, qf, sf, final: finalP, champion, champMax } = Astro.props;

const isGold   = rank === 1;
const isSilver = rank === 2;
const isBronze = rank === 3;

const border = isGold   ? 'border-amber-600/50'
             : isSilver ? 'border-slate-400/30'
             : isBronze ? 'border-orange-700/40'
             :            'border-slate-800/60';

const bg = isGold   ? 'bg-amber-950/25'
         : isSilver ? 'bg-slate-800/20'
         : isBronze ? 'bg-orange-950/20'
         :            'bg-slate-900/50';

const rnkClr = isGold   ? 'text-amber-400'
             : isSilver ? 'text-slate-400'
             : isBronze ? 'text-orange-400'
             :            'text-slate-600';

const chpClr = isGold   ? 'text-amber-200'
             : isSilver ? 'text-slate-100'
             : isBronze ? 'text-orange-200'
             :            'text-blue-300';

const barClr = isGold   ? 'bg-amber-500/70'
             : isSilver ? 'bg-slate-400/60'
             : isBronze ? 'bg-orange-500/60'
             :            'bg-blue-600/60';

const relW = champMax > 0 ? ((champion / champMax) * 100).toFixed(1) + '%' : '4%';

interface Stage { label: string; val: number }
const stages: Stage[] = [
  { label: 'Qual',  val: qualify },
  { label: 'R16',   val: r16 },
  { label: 'QF',    val: qf },
  { label: 'SF',    val: sf },
  { label: 'Final', val: finalP },
];
---

<div class={`rounded-xl border ${border} ${bg} p-5`}>
  <div class="flex items-start justify-between gap-2 mb-3">
    <div class="min-w-0">
      <div class={`text-[10px] font-bold uppercase tracking-widest mb-0.5 ${rnkClr}`}>#{rank}</div>
      <div class="text-base font-bold text-slate-100 truncate leading-tight">{formatTeamName(team)}</div>
    </div>
    <div class="text-right shrink-0">
      <div class={`text-3xl font-bold tabular-nums leading-none ${chpClr}`}>{formatPct(champion)}</div>
      <div class="text-[9px] uppercase tracking-widest text-slate-700 mt-1">to win</div>
    </div>
  </div>

  <div class="h-1 bg-slate-800/80 rounded-full overflow-hidden mb-4">
    <div class={`h-full rounded-full ${barClr}`} style={`width:${relW}`} />
  </div>

  <div class="grid grid-cols-5 gap-0.5 text-center">
    {stages.map(s => (
      <div>
        <div class="text-[9px] uppercase tracking-wider text-slate-700 mb-0.5">{s.label}</div>
        <div class="text-[11px] tabular-nums text-slate-500">{formatPct(s.val, 0)}</div>
      </div>
    ))}
  </div>
</div>
