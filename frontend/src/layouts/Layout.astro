---
import NavBar from '../components/NavBar.astro';

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
}

const {
  title,
  description = 'World Cup Oracle — statistical match probabilities and model-market gap signals for the FIFA 2026 World Cup. Educational use only.',
  ogTitle,
} = Astro.props;

const pageTitle = title === 'Overview' ? 'World Cup Oracle — 2026 Betting Intelligence' : `${title} — World Cup Oracle`;
const ogT = ogTitle ?? pageTitle;
const canonicalUrl = Astro.url.href;
---
<!doctype html>
<html lang="en" class="bg-[#06091A] text-slate-100">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>

    <!-- Open Graph -->
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={ogT} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogT} />
    <meta name="twitter:description" content={description} />
  </head>
  <body class="min-h-screen bg-[#06091A] antialiased">
    <NavBar />
    <main class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
      <slot />
    </main>
    <footer class="border-t border-slate-800/60 mt-20 py-8">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-slate-600">
        <div class="flex items-center gap-2">
          <span class="text-slate-500 font-medium">World Cup Oracle</span>
          <span>·</span>
          <span>Statistical models only. Not betting advice.</span>
        </div>
        <div class="flex items-center gap-4">
          <a href="/tournament" class="hover:text-slate-400 transition-colors">Tournament</a>
          <a href="/bracket" class="hover:text-slate-400 transition-colors">Bracket</a>
          <a href="/lab" class="hover:text-slate-400 transition-colors">Lab</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  /* ── Design tokens ────────────────────────────────────────────────────────── */
  :root {
    --oracle-bg: #06091A;
    --oracle-surface: rgba(15, 22, 41, 0.6);
    --oracle-border: rgba(30, 41, 59, 0.7);
    --oracle-text-muted: #64748b;
    --oracle-accent: #22d3ee;
    --oracle-warning: #f59e0b;
  }

  /* ── Reduced motion ───────────────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
  }

  /* ── Global focus ring (keyboard-only, !important to override utility classes) */
  *:focus-visible {
    outline: 2px solid #94a3b8 !important; /* slate-400 */
    outline-offset: 3px !important;
    border-radius: 4px !important;
  }
  *:focus:not(:focus-visible) {
    outline: none;
  }
</style>
